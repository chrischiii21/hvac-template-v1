---
import { Image } from "astro:assets";
import { siteConfig } from "@/config/site";
import Button from "./Button.astro";

interface Props {
  delay?: number;
  showOnce?: boolean;
  triggerId?: string;
}

const { delay = 3000, showOnce = true, triggerId = "open-popup" } = Astro.props;
---

<div
  id="promo-popup"
  class="popup-overlay hidden"
  data-delay={delay}
  data-show-once={showOnce}
  data-trigger-id={triggerId}
  role="dialog"
  aria-labelledby="popup-title"
  aria-modal="true"
>
  <div class="popup-backdrop"></div>

  <div class="popup-container">
    <!-- Close button -->
    <button id="close-popup" class="popup-close" aria-label="Close popup">
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2.5"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- ═══ Clean Cinematic Voucher Layout ═══ -->
    <div class="popup-voucher group">
      <!-- Left: Brand & Hero Offer -->
      <div class="voucher-hero">
        <div class="absolute inset-0 z-0">
          <Image
            src="https://johnh967.sg-host.com/wp-content/uploads/sb-instagram-feed-images/466555884_570355772412079_4111747127252492406_nfull.webp"
            alt="HVAC Special"
            class="hero-img"
            widths={[300, 450, 600, 900]}
            sizes="(max-width: 900px) 100vw, 450px"
            inferSize={true}
            format="webp"
            quality={60}
            loading="lazy"
            fetchpriority="low"
          />
          <div class="hero-overlay"></div>
        </div>

        <div class="hero-content relative z-10">
          <div class="hero-eyebrow">
            <span class="status-dot"></span>
            Limited Time Offer
          </div>
          <div class="hero-price">
            <span class="hero-currency">$</span>
            <span class="hero-amount">69</span>
          </div>
          <div class="hero-label">Special</div>
        </div>

        <!-- Design accents -->
        <div class="voucher-notch top"></div>
        <div class="voucher-notch bottom"></div>
      </div>

      <!-- Right: Content & CTA -->
      <div class="voucher-body">
        <div class="voucher-content-scroll">
          <div class="body-header">
            <h2 id="popup-title" class="body-title">Service Special</h2>
            <p class="body-subtitle">Complete HVAC System Diagnostic</p>
          </div>

          <div class="body-divider"></div>

          <div class="body-features">
            <div class="feature-item">
              <div class="feature-check">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <path
                    d="M20 6L9 17l-5-5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <span>Complete system inspection</span>
            </div>
            <div class="feature-item">
              <div class="feature-check">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <path
                    d="M20 6L9 17l-5-5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <span>Performance & efficiency report</span>
            </div>
            <div class="feature-item">
              <div class="feature-check">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                >
                  <path
                    d="M20 6L9 17l-5-5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <span>No hidden fees or obligations</span>
            </div>
          </div>

          <div class="body-actions">
            <Button
              href="/contact"
              variant="primary"
              showArrow={true}
              size="lg"
              className="w-full"
            >
              Schedule Online
            </Button>
            <Button
              href={`tel:${siteConfig.contact.phone}`}
              variant="outline"
              size="lg"
              className="w-full"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              Call {siteConfig.contact.phoneFormatted}
            </Button>
          </div>

          <div class="body-footer">
            <div class="popup-trust">
              <span class="trust-pill">
                <span class="trust-dot"></span>
                Fast Response
              </span>
              <span class="trust-pill">
                <span class="trust-dot"></span>
                Licensed & Insured
              </span>
            </div>
            <button id="close-popup-bottom" class="popup-dismiss">No thanks, maybe later</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ═══ Core Popup Styles ═══ */
  .popup-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    transition: visibility 0.3s, opacity 0.3s ease-out;
  }
  .popup-overlay.show {
    opacity: 1;
    visibility: visible;
  }

  .popup-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--background) 35%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .popup-container {
    position: relative;
    width: 100%;
    max-width: 940px;
    z-index: 10;
    transform: translateY(20px) scale(0.98);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .popup-overlay.show .popup-container {
    transform: translateY(0) scale(1);
  }

  .popup-close {
    position: absolute;
    top: -0.75rem;
    right: -0.75rem;
    width: 2.75rem;
    height: 2.75rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 30;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }
  .popup-close:hover {
    transform: rotate(90deg) scale(1.1);
  }

  /* ═══ Voucher Design ═══ */
  .popup-voucher {
    background: var(--card);
    display: flex;
    border-radius: 0;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.3);
    border: 1px solid color-mix(in srgb, var(--brand-primary) 5%, transparent);
    min-height: 540px;
    max-height: 90vh;
  }

  /* Left: Hero Visual */
  .voucher-hero {
    position: relative;
    width: 50%;
    background: var(--brand-primary);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 3.5rem;
    text-align: center;
    flex-shrink: 0;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
    transition: transform 1.2s ease;
  }
  .popup-voucher:hover .hero-img {
    transform: scale(1.05);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(var(--brand-primary-rgb), 0.75),
      rgba(var(--brand-primary-rgb), 0.95)
    );
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    padding: 0.45rem 1rem;
    border-radius: 0;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    background: var(--brand-primary);
    border-radius: 0;
    animation: pulse 2s infinite;
  }

  .hero-price {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    color: #fff;
    margin-bottom: 0.5rem;
  }
  .hero-currency {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--brand-highlight);
    margin-top: 1rem;
    margin-right: 0.25rem;
  }
  .hero-amount {
    font-size: 9.5rem;
    font-weight: 950;
    line-height: 0.9;
    letter-spacing: -0.05em;
    background: linear-gradient(to bottom, #fff, #ddd);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.3));
  }
  .hero-label {
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: var(--brand-highlight);
    opacity: 0.9;
    margin-top: 0.5rem;
  }

  /* Decorative Notches */
  .voucher-notch {
    position: absolute;
    right: -1rem;
    width: 2rem;
    height: 2rem;
    background: var(--background);
    border-radius: 0;
    z-index: 5;
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.1);
  }
  .voucher-notch.top {
    top: -1rem;
  }
  .voucher-notch.bottom {
    bottom: -1rem;
  }

  /* Right: Body Content */
  .voucher-body {
    width: 50%;
    background: var(--card);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .voucher-content-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 3rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.1) transparent;
  }
  .voucher-content-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .voucher-content-scroll::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 0;
  }

  .body-header {
    margin-bottom: 1.5rem;
  }
  .body-title {
    font-size: 2.5rem;
    font-weight: 950;
    color: var(--brand-primary);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .body-subtitle {
    font-size: 1.1rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--brand-primary) 60%, transparent);
    letter-spacing: 0.01em;
  }

  .body-divider {
    width: 3.5rem;
    height: 3px;
    background: var(--brand-highlight);
    margin-bottom: 2rem;
    border-radius: 0;
  }

  .body-features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--brand-primary);
  }
  .feature-check {
    width: 1.5rem;
    height: 1.5rem;
    background: color-mix(in srgb, var(--brand-highlight) 15%, transparent);
    color: var(--brand-highlight);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    flex-shrink: 0;
  }

  .body-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .body-footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid
      color-mix(in srgb, var(--brand-primary) 10%, transparent);
  }
  
  .popup-trust {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }
  .trust-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--brand-primary) 40%, transparent);
  }
  .trust-dot {
    width: 4px;
    height: 4px;
    background: var(--brand-highlight);
    border-radius: 0;
  }

  .popup-dismiss {
    display: block;
    width: fit-content;
    margin: 0 auto;
    background: none;
    border: none;
    color: color-mix(in srgb, var(--brand-primary) 35%, transparent);
    font-size: 0.75rem;
    font-weight: 800;
    cursor: pointer;
    padding: 0.5rem 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }
  .popup-dismiss:hover {
    color: var(--brand-primary);
    opacity: 1;
    transform: translateY(-1px);
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 900px) {
    .popup-container {
      max-width: 500px;
    }
    .popup-voucher {
      flex-direction: column;
      min-height: auto;
      max-height: 85vh;
    }
    .voucher-hero,
    .voucher-body {
      width: 100%;
    }
    .voucher-hero {
      padding: 2.5rem;
    }
    .voucher-body {
      overflow-y: hidden;
    }
    .voucher-content-scroll {
      padding: 2.5rem;
    }
    .voucher-notch {
      display: none;
    }
    .hero-amount {
      font-size: 7rem;
    }
    .body-title {
      font-size: 2.25rem;
    }
    .popup-trust {
      flex-direction: column;
      gap: 0.75rem;
    }
  }

  @keyframes pulse {
    0% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.8);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script is:inline>
  function setupPopup() {
    const popup = document.getElementById("promo-popup");
    const closeBtn = document.getElementById("close-popup");
    const dismissBtn = document.getElementById("close-popup-bottom");
    if (!popup || !closeBtn) return;

    const delay = parseInt(popup.getAttribute("data-delay") || "3000");
    const showOnce = popup.getAttribute("data-show-once") === "true";

    const getCookie = (name) => {
      const value = `; ${document.cookie}`;
      const parts = value.split(`; ${name}=`);
      if (parts.length === 2) return parts.pop().split(";").shift();
    };

    const setCookie = (name, value, days) => {
      let expires = "";
      if (days) {
        const date = new Date();
        date.setTime(date.getTime() + days * 24 * 60 * 60 * 1000);
        expires = `; expires=${date.toUTCString()}`;
      }
      document.cookie = `${name}=${value || ""}${expires}; path=/`;
    };

    const showPopup = () => {
      if (showOnce && getCookie("promo_popup_viewed")) return;
      setTimeout(() => {
        popup.classList.add("show");
        document.body.style.overflow = "hidden";
      }, delay);
    };

    const hidePopup = () => {
      popup.classList.remove("show");
      document.body.style.overflow = "";
      if (showOnce) setCookie("promo_popup_viewed", "true", 30);
    };

    closeBtn.addEventListener("click", hidePopup);
    if (dismissBtn) dismissBtn.addEventListener("click", hidePopup);
    
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && popup.classList.contains("show")) hidePopup();
    });
    popup.querySelector(".popup-backdrop").addEventListener("click", hidePopup);

    const externalTriggerId = popup.getAttribute("data-trigger-id");
    if (externalTriggerId) {
      const trigger = document.getElementById(externalTriggerId);
      if (trigger) {
        trigger.addEventListener("click", (e) => {
          e.preventDefault();
          popup.classList.add("show");
          document.body.style.overflow = "hidden";
        });
      }
    }

    showPopup();
  }

  document.addEventListener("astro:page-load", setupPopup);
  setupPopup();
</script>
