---
interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "white" | "outline" | "ghost" | "glass";
  size?: "sm" | "md" | "lg" | "xl";
  rounded?: "full" | "2xl" | "none";
  className?: string;
  showArrow?: boolean;
}

const {
  href,
  type = "button",
  variant = "primary",
  size = "md",
  rounded = "2xl",
  className = "",
  showArrow = false,
} = Astro.props;

const baseStyles =
  "relative inline-flex items-center justify-center gap-3 font-black uppercase tracking-widest transition-all duration-300 overflow-hidden shadow-lg group/btn";

const variants = {
  primary:
    "bg-[var(--brand-primary)] text-white hover:text-[var(--brand-primary)]",
  secondary:
    "bg-[var(--brand-highlight)] text-[var(--brand-primary)] hover:text-white",
  white:
    "bg-white text-[var(--brand-primary)] hover:text-[var(--brand-primary)]",
  outline:
    "bg-transparent border-2 border-[var(--brand-highlight)] text-[var(--brand-highlight)] hover:text-[var(--brand-primary)]",
  ghost:
    "bg-transparent text-[var(--brand-primary)] hover:bg-[var(--brand-primary)]/5",
  glass:
    "bg-white/5 backdrop-blur-2xl border border-white/10 text-white hover:border-white/40 hover:shadow-[0_0_25px_rgba(255,255,255,0.1)]",
};

const hoverFills = {
  primary: "bg-[var(--brand-highlight)]",
  secondary: "bg-[var(--brand-primary)]",
  white: "bg-[var(--brand-highlight)]",
  outline: "bg-[var(--brand-highlight)]",
  ghost: "hidden",
  glass: "bg-white/10",
};

const sizes = {
  sm: "py-2.5 px-6 text-[0.65rem] tracking-[0.2em]",
  md: "py-4 px-10 text-[0.8rem] tracking-[0.15em]",
  lg: "py-5 px-12 text-[0.9rem] tracking-[0.15em]",
  xl: "py-6 px-16 text-[1rem] tracking-[0.15em]",
};

const rounding = {
  full: "rounded-full",
  "2xl": "rounded-2xl",
  none: "rounded-none",
};

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={href ? undefined : type}
  class:list={[
    baseStyles,
    variants[variant],
    sizes[size],
    rounding[rounded],
    className,
  ]}
>
  {/* Cinematic Hover Fill */}
  {
    hoverFills[variant] !== "hidden" && (
      <div
        class:list={[
          "absolute inset-0 w-0 transition-all duration-500 ease-out group-hover/btn:w-full z-[0]",
          hoverFills[variant],
        ]}
      />
    )
  }

  <span
    class="relative z-10 transition-colors duration-300 flex items-center gap-3"
  >
    <slot />
    {
      showArrow && (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 transition-transform duration-300 group-hover/btn:translate-x-1"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      )
    }
  </span>
</Tag>
