---
import Button from "./ui/Button.astro";
import { siteConfig } from "@/config/site"
import { utilityNavItems, mainNavItems, quickActions } from "@/config/navigation"
---

<!-- Hidden checkbox — CSS-only mobile drawer toggle, zero JS -->
<input type="checkbox" id="nb-mobile-toggle" class="nb-mobile-toggle-input" aria-hidden="true" />

<header class="nb-header">
  <div class="nb-container">
    <div class="nb-glass-card">
      
      <!-- ── Row 1: Utility & Actions (Desktop) ── -->
      <div class="nb-top-row">
         <div class="nb-quick-actions">
           {quickActions.map((action) => (
             <Button href={action.href} variant="outline" size="sm" rounded="2xl">
               {action.title}
             </Button>
           ))}
         </div>

        <nav class="nb-utility-nav" aria-label="Utility navigation">
          {utilityNavItems.map((item) => (
            item.children ? (
              <div class="nb-dropdown-wrapper">
                <a href={item.href} class="nb-util-link">
                  {item.title}
                  <svg class="nb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
                </a>
                <div class="nb-dropdown-panel">
                  <div class="nb-dropdown-inner">
                    {item.children.map((child) => (
                      <a href={child.href} class="nb-dropdown-item">{child.title}</a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a href={item.href} class="nb-util-link">{item.title}</a>
            )
          ))}
        </nav>
      </div>

      <!-- ── Row 2: Main Navigation ── -->
      <div class="nb-main-row">
        <!-- Logo -->
        <a href="/" class="nb-logo" aria-label={`${siteConfig.business.name} - Home`}>
          <div class="nb-logo-icon-wrapper">
            <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} class="nb-logo-img" width="44" height="44" decoding="async" loading="eager" />
          </div>
          <span class="nb-logo-name">{siteConfig.business.name}</span>
        </a>

        <!-- Desktop Main Nav -->
        <nav class="nb-service-nav" aria-label="Service navigation">
          {mainNavItems.map((item) => (
            <div class="nb-nav-item">
              <a href={item.href} class="nb-nav-link">
                {item.title}
                <svg class="nb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
              </a>
              <span class="nb-nav-underline" aria-hidden="true"></span>
              
              <!-- Mega Menu -->
              <div class="nb-mega-menu" role="region" aria-label={`${item.title} submenu`}>
                <div class="nb-mega-inner">
                  <div class="nb-mega-grid">
                    {item.categories.flatMap((cat) => cat.items).map((service) => (
                      <a href={service.href} class="nb-mega-link">
                        <span class="nb-mega-dot" aria-hidden="true"></span>
                        {service.title}
                      </a>
                    ))}
                  </div>
                  <div class="nb-mega-footer">
                    <a href={item.href} class="nb-mega-view-all">
                      View all {item.title}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </nav>

        <!-- Phone & Mobile Toggle -->
        <div class="nb-main-actions">
          <a href={`tel:${siteConfig.contact.phone}`} class="nb-phone-btn cta-pulse">
            <div class="nb-phone-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div class="nb-phone-text">
              <span class="nb-phone-label">Call Now</span>
              <span class="nb-phone-number">{siteConfig.contact.phoneFormatted}</span>
            </div>
          </a>

          <label for="nb-mobile-toggle" class="nb-hamburger" aria-label="Open menu" role="button" tabindex="0">
            <div class="nb-ham-box">
              <span class="nb-ham-line top"></span>
              <span class="nb-ham-line middle"></span>
              <span class="nb-ham-line bottom"></span>
            </div>
          </label>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Mobile drawer — pure CSS, no JS -->
<div class="nb-mobile-drawer" id="mobile-nav" role="dialog" aria-label="Mobile navigation">
  <!-- Backdrop -->
  <label for="nb-mobile-toggle" class="nb-backdrop" aria-hidden="true"></label>

  <!-- Drawer panel -->
  <div class="nb-drawer-panel">
    <!-- Drawer Header -->
    <div class="nb-drawer-header">
      <div class="nb-drawer-logo">
        <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} width="32" height="32" />
        <span>{siteConfig.business.name}</span>
      </div>
      <label for="nb-mobile-toggle" class="nb-drawer-close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </label>
    </div>

    <!-- Quick actions (Fixed at top) -->
    <div class="nb-drawer-actions nb-drawer-actions--sticky">
      {quickActions.map((action) => (
        <Button href={action.href} variant="secondary" size="sm" rounded="2xl" className="w-full">
          {action.title}
        </Button>
      ))}
    </div>

    <div class="nb-drawer-content">

      <!-- Utility links (Company) -->
      <div class="nb-drawer-section">
        <p class="nb-drawer-label">Company</p>
        {utilityNavItems.map((item) => (
          item.children ? (
            <details class="nb-drawer-details">
              <summary class="nb-drawer-summary">
                {item.title}
                <svg class="nb-drawer-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="nb-drawer-children">
                {item.children.map((child) => (
                  <a href={child.href} class="nb-drawer-child">{child.title}</a>
                ))}
              </div>
            </details>
          ) : (
            <a href={item.href} class="nb-drawer-link">{item.title}</a>
          )
        ))}
      </div>

      <!-- Services -->
      <div class="nb-drawer-section">
        <p class="nb-drawer-label">Our Services</p>
        {mainNavItems.map((service) => (
          <details class="nb-drawer-details">
            <summary class="nb-drawer-summary">
              {service.title}
              <svg class="nb-drawer-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="nb-drawer-children">
              {service.categories.flatMap((cat) => cat.items).map((link) => (
                <a href={link.href} class="nb-drawer-child">{link.title}</a>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- Phone CTA Fixed Bottom -->
    <div class="nb-drawer-footer">
      <a href={`tel:${siteConfig.contact.phone}`} class="nb-drawer-phone-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Call Us Now
      </a>
    </div>
  </div>
</div>

<style>
  /* ── Core Variables & Setup ── */
  :root {
    --nav-height: 84px;
    --nav-glass-bg: rgba(255, 255, 255, 0.98);
    --nav-glass-border: rgba(255, 255, 255, 0.5);
    --nav-glass-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
  }

  .nb-header {
    --nav-text: var(--brand-primary);
    --nav-text-muted: color-mix(in srgb, var(--brand-primary) 60%, transparent);
    transition: all 0.3s ease;
  }

  .dark {
    --nav-glass-bg: rgba(14, 12, 26, 0.98);
    --nav-glass-border: rgba(255, 255, 255, 0.08);
    --nav-glass-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
  }
  .dark .nb-header {
    --nav-text: #f1f0f9;
    --nav-text-muted: color-mix(in srgb, #f1f0f9 60%, transparent);
  }
  
  .dark .nb-dropdown-panel, .dark .nb-mega-inner {
    --mega-text: #f1f0f9;
    --mega-text-muted: color-mix(in srgb, #f1f0f9 60%, transparent);
  }

  .nb-mobile-toggle-input {
    position: fixed; opacity: 0; pointer-events: none;
  }

  /* ── Header Container ── */
  .nb-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    padding-top: 1rem;
    pointer-events: none; /* Let clicks pass through margins */
  }

  .nb-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
    pointer-events: auto;
  }

  /* ── Floating Glass Card ── */
  .nb-glass-card {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 1.25rem;
    display: flex;
    flex-direction: column;
    overflow: visible;
    position: relative;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nb-header.is-scrolled .nb-glass-card {
    background: var(--nav-glass-bg);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border: 1px solid var(--nav-glass-border);
    box-shadow: var(--nav-glass-shadow);
  }

  /* ── Top Row (Desktop Only) ── */
  .nb-top-row {
    display: none;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1.5rem;
    border-bottom: 1px solid transparent;
    transition: border-color 0.4s ease;
  }
  .nb-header.is-scrolled .nb-top-row {
    border-bottom: 1px solid color-mix(in srgb, var(--nav-text) 8%, transparent);
  }
  @media (min-width: 1024px) { .nb-top-row { display: flex; } }

  .nb-quick-actions, .nb-utility-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nb-utility-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nb-util-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--nav-text-muted);
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nb-chevron { width: 14px; height: 14px; }
  .nb-util-link:hover { color: var(--brand-highlight); }

  /* Dropdowns in Top Row */
  .nb-dropdown-wrapper { position: relative; }
  .nb-dropdown-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    padding-top: 1rem; /* Hover-safe bridge */
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 150;
    --mega-text: var(--brand-primary);
    --mega-text-muted: color-mix(in srgb, var(--brand-primary) 60%, transparent);
  }

  .nb-dropdown-wrapper:hover .nb-dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nb-dropdown-inner {
    background: var(--nav-glass-bg);
    backdrop-filter: blur(30px);
    border: 1px solid var(--nav-glass-border);
    border-radius: 0.75rem;
    padding: 0.5rem;
    min-width: 180px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .nb-dropdown-item {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--mega-text);
    text-decoration: none;
    border-radius: 0.375rem;
    transition: all 0.2s;
  }
  .nb-dropdown-item:hover {
    background: color-mix(in srgb, var(--brand-highlight) 15%, transparent);
    color: var(--brand-highlight);
  }

  /* ── Main Row ── */
  .nb-main-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    padding: 0 1rem;
  }
  @media (min-width: 1024px) {
    .nb-main-row { padding: 0 1.5rem; height: 80px; }
  }

  /* Logo */
  .nb-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .nb-logo-icon-wrapper {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    background: var(--brand-secondary);
    border-radius: 0.5rem;
    padding: 0.25rem;
  }
  .nb-logo-img {
    width: 100%; height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  .nb-logo-name {
    font-size: 1.125rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--nav-text);
    background: linear-gradient(135deg, var(--brand-secondary), var(--brand-highlight));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: none;
  }
  @media (min-width: 640px) { .nb-logo-name { display: block; } }

  /* Desktop Main Nav */
  .nb-service-nav {
    display: none;
    height: 100%;
    align-items: center;
    gap: 0.5rem;
  }
  @media (min-width: 1024px) { .nb-service-nav { display: flex; } }

  .nb-nav-item {
    height: 100%;
    display: flex;
    align-items: center;
    position: static; /* Mega menu positioning */
  }
  .nb-nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--nav-text);
    text-decoration: none;
    border-radius: 2rem;
    transition: all 0.2s;
  }
  .nb-nav-item:hover .nb-nav-link {
    background: color-mix(in srgb, var(--brand-highlight) 10%, transparent);
    color: var(--brand-highlight);
  }

  /* Mega Menu (Floating Card) */
  .nb-mega-menu {
    position: absolute;
    top: 100%;
    left: 1.5rem; 
    right: 1.5rem;
    padding-top: 1rem; /* The visual gap is now a hover-safe bridge */
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 150;
    pointer-events: none;
  }

  .nb-nav-item:hover .nb-mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  
  .nb-mega-inner {
    --mega-text: var(--brand-primary);
    --mega-text-muted: color-mix(in srgb, var(--brand-primary) 60%, transparent);
    background: var(--nav-glass-bg);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid var(--nav-glass-border);
    border-radius: 1.25rem;
    box-shadow: 0 20px 50px -10px rgba(0,0,0,0.15);
    padding: 2rem;
    overflow: hidden;
  }

  .nb-mega-menu::before {
    content: '';
    position: absolute;
    top: -2rem;
    left: 0;
    right: 0;
    height: 2rem;
  }

  .nb-mega-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem 2rem;
    margin-bottom: 2rem;
  }

  .nb-mega-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--mega-text);
    text-decoration: none;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.2s;
  }
  .nb-mega-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--mega-text-muted);
    transition: all 0.2s;
  }
  .nb-mega-link:hover {
    background: color-mix(in srgb, var(--brand-highlight) 10%, transparent);
    color: var(--brand-highlight);
  }
  .nb-mega-link:hover .nb-mega-dot {
    background: var(--brand-highlight);
    transform: scale(1.5);
  }

  .nb-mega-footer {
    display: flex;
    justify-content: center;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--mega-text) 10%, transparent);
  }
  .nb-mega-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--brand-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nb-mega-view-all svg { width: 16px; height: 16px; transition: transform 0.2s; }
  .nb-mega-view-all:hover { color: var(--brand-highlight); }
  .nb-mega-view-all:hover svg { transform: translateX(4px); }

  /* Main Actions (Phone & Ham) */
  .nb-main-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Premium Phone CTA */
  .nb-phone-btn {
    display: none;
    align-items: center;
    gap: 0.75rem;
    background: var(--brand-secondary);
    color: #fff;
    padding: 0.375rem 1rem 0.375rem 0.375rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid transparent;
  }
  @media (min-width: 1024px) { .nb-phone-btn { display: flex; } }
  
  .nb-phone-btn:hover {
    background: #fff;
    color: var(--brand-secondary);
    border-color: var(--brand-secondary);
    transform: translateY(-2px);
  }
  
  .nb-phone-icon {
    width: 36px; height: 36px;
    background: #fff;
    color: var(--brand-secondary);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s;
  }
  .nb-phone-icon svg { width: 18px; height: 18px; }
  .nb-phone-btn:hover .nb-phone-icon {
    background: var(--brand-secondary);
    color: #fff;
  }

  .nb-phone-text {
    display: flex; flex-direction: column;
    line-height: 1.2;
  }
  .nb-phone-label { font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.9; }
  .nb-phone-number { font-size: 1rem; font-weight: 800; }

  /* Hamburger Toggle */
  .nb-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    background: color-mix(in srgb, var(--nav-text) 5%, transparent);
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  @media (min-width: 1024px) { .nb-hamburger { display: none; } }
  .nb-hamburger:hover { background: color-mix(in srgb, var(--brand-highlight) 15%, transparent); }
  
  .nb-ham-box { width: 20px; height: 14px; position: relative; }
  .nb-ham-line {
    position: absolute; left: 0; width: 100%; height: 2px;
    background: var(--nav-text); border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nb-ham-line.top { top: 0; }
  .nb-ham-line.middle { top: 6px; }
  .nb-ham-line.bottom { top: 12px; }

  /* ── Mobile Drawer Refined ── */
  .nb-mobile-drawer {
    position: fixed; inset: 0; z-index: 200;
    pointer-events: none; visibility: hidden;
  }
  .nb-mobile-toggle-input:checked ~ .nb-mobile-drawer {
    pointer-events: auto; visibility: visible;
  }

  .nb-backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
    opacity: 0; transition: opacity 0.3s; cursor: pointer;
  }
  .nb-mobile-toggle-input:checked ~ .nb-mobile-drawer .nb-backdrop { opacity: 1; }

  .nb-drawer-panel {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(360px, 100vw);
    background: var(--background);
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: -10px 0 40px rgba(0,0,0,0.2);
  }
  .nb-mobile-toggle-input:checked ~ .nb-mobile-drawer .nb-drawer-panel { transform: translateX(0); }

  .nb-drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .nb-drawer-logo {
    display: flex; align-items: center; gap: 0.75rem;
    font-weight: 800; font-size: 1rem; color: var(--foreground);
  }
  .nb-drawer-logo img { border-radius: 0.375rem; background: var(--brand-secondary); padding: 0.2rem; filter: brightness(0) invert(1); }
  
  .nb-drawer-close {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: var(--muted); border-radius: 50%;
    color: var(--foreground); cursor: pointer;
    transition: all 0.2s;
  }
  .nb-drawer-close svg { width: 18px; height: 18px; }
  .nb-drawer-close:hover { background: var(--destructive); color: #fff; transform: rotate(90deg); }

  .nb-drawer-content {
    flex: 1; overflow-y: auto;
    padding-bottom: 2rem;
    /* Hide scrollbar */
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .nb-drawer-content::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }

  .nb-drawer-section { padding: 1.5rem; }
  .nb-drawer-section--alt { background: var(--muted); }
  
  .nb-drawer-label {
    font-size: 0.75rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--brand-secondary);
    margin-bottom: 1rem;
  }

  .nb-drawer-details { border-bottom: 1px solid color-mix(in srgb, var(--border) 50%, transparent); }
  .nb-drawer-details:last-child { border-bottom: none; }
  
