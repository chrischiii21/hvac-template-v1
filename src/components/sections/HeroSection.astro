---
import { Image, getImage } from "astro:assets";
import Button from "../ui/Button.astro";
const bg2Img = "/images/bg2.jpg";
import { getLocationText } from "@/config/site"

const defaultHeroImages = [
  "https://f.hubspotusercontent40.net/hubfs/9492292/AdobeStock_290366802.jpeg",
  "https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=1920&q=80",
  "https://images.pexels.com/photos/34069/pexels-photo.jpg?auto=compress&w=1920",
];

// Check if a URL is a remote image we can optimize via Astro
const isRemoteImage = (url: string) => url.startsWith('http://') || url.startsWith('https://');

interface Props {
  variant?: "slider" | "subpage";
  buttonHref?: string;
  showArrow?: boolean;
  // Slider-specific props
  images?: string[];
  // Subpage-specific props
  badge?: string;
  title?: string;
  subtitle?: string;
  buttonText?: string;
  image?: string;
  imageAlt?: string;
  trustIndicators?: string[];
}

const {
  variant = "slider",
  buttonHref = "#",
  showArrow = true,
  images,
  badge,
  title: subpageTitle,
  subtitle: subpageSubtitle,
  buttonText: subpageButtonText = "SCHEDULE SERVICE",
  image: subpageImage,
  imageAlt = "HVAC service",
  trustIndicators,
} = Astro.props;

const heroImages = images && images.length > 0 ? images : defaultHeroImages;

const slides = [
  {
    title: "Fast, Reliable, & Affordable Service",
    subtitle: "Need HVAC Repair or New Installation? We've Got You Covered!",
    buttonText: "Schedule a Call",
    statNumber: "$99",
    statLabel: "Service Call",
    statDescription: "Expert Repairs & Installation included with every visit.",
    bgImage: heroImages[0 % heroImages.length],
  },
  {
    title: "Flexible Financing Available",
    subtitle: "No Interest. No Payments. Until 2026!",
    buttonText: "Learn More",
    statNumber: "0%",
    statLabel: "Interest",
    statDescription: "With approved financing. Ask us about our flexible plans.",
    bgImage: heroImages[1 % heroImages.length],
  },
  {
    title: "Limited Time Offer — Don't Miss Out!",
    subtitle: "Furnace Tune-Up Special! Only $95 with Coupon!",
    buttonText: "Call Now",
    statNumber: "1yr",
    statLabel: "Warranty",
    statDescription: "Warranty on furnace repair. Expert maintenance for peak efficiency.",
    bgImage: heroImages[2 % heroImages.length],
  },
];

const isSlider = variant === "slider";

// Preload the first hero image for LCP optimization
const firstSlideImage = isSlider 
  ? await getImage({
      src: slides[0].bgImage,
      width: 1920,
      height: 1080,
      format: 'avif',
      quality: 85,
      inferSize: true
    })
  : subpageImage 
    ? await getImage({
        src: subpageImage,
        width: 1920,
        height: 1080,
        format: 'avif',
        quality: 85,
        inferSize: true
      })
    : await getImage({
        src: bg2Img,
        width: 1920,
        height: 1080,
        format: 'avif',
        quality: 85,
        inferSize: true
      });
---

<link rel="preload" href={firstSlideImage.src} as="image" slot="head" fetchpriority="high" />

{isSlider ? (
<section class="hero-cinematic relative w-full overflow-hidden min-h-[90vh] flex flex-col justify-center items-center bg-[var(--brand-primary)]">
  
  <!-- Background images -->
  <div class="absolute inset-0 z-0">
    {slides.map((slide, i) => (
      <div class={`img-slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-index={i}>
        {isRemoteImage(slide.bgImage) ? (
          <Image
            src={slide.bgImage}
            alt="HVAC background"
            class="absolute inset-0 w-full h-full object-cover scale-105"
            loading={i === 0 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : "auto"}
            decoding={i === 0 ? "sync" : "async"}
            widths={[390, 640, 800, 1200, 1600]}
            sizes="(max-width: 768px) 100vw, 100vw"
            inferSize={true}
            format="avif"
            quality={i === 0 ? 60 : 50}
          />
        ) : (
          <img
            src={slide.bgImage}
            alt="HVAC background"
            class="absolute inset-0 w-full h-full object-cover scale-105"
            loading={i === 0 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : "auto"}
            decoding={i === 0 ? "sync" : "async"}
            width="1920"
            height="1080"
          />
        )}
      </div>
    ))}
  </div>
  
  <!-- Cinematic Vignette Overlays -->
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--brand-primary)]/80 via-transparent to-[var(--brand-primary)]/90 mix-blend-multiply z-[1]"></div>
  <div class="absolute inset-0 bg-black/30 z-[1]"></div>

  <!-- Center Text Slider & HUD -->
  <div class="relative z-[2] container mx-auto px-4 md:px-6 flex-1 flex flex-col justify-center items-center text-center pt-32 pb-32 lg:pt-40 lg:pb-40">
    <div class="text-slider-grid w-full max-w-5xl mx-auto mb-6 md:mb-10">
      {slides.map((slide, i) => (
        <div class={`text-slide transition-all duration-700 ease-out ${i === 0 ? 'opacity-100 scale-100 pointer-events-auto' : 'opacity-0 scale-95 pointer-events-none'}`} data-index={i}>
          {i === 0 ? (
            <h1 class="hero-title text-4xl sm:text-5xl md:text-6xl lg:text-[5.5rem] font-black leading-[0.95] mb-3 md:mb-4 uppercase tracking-tight text-white drop-shadow-2xl">
              {getLocationText(slide.title)}
            </h1>
          ) : (
            <div class="hero-title text-4xl sm:text-5xl md:text-6xl lg:text-[5.5rem] font-black leading-[0.95] mb-3 md:mb-4 uppercase tracking-tight text-white drop-shadow-2xl">
              {getLocationText(slide.title)}
            </div>
          )}
          <p class="hero-subtitle text-base sm:text-lg md:text-2xl leading-relaxed text-white/80 font-medium max-w-3xl mx-auto drop-shadow-lg px-4">
            {getLocationText(slide.subtitle)}
          </p>
        </div>
      ))}
    </div>

    <!-- Glass HUD Dashboard (Pill) - Persistent -->
    <div class="z-[10] w-full max-w-[95%] md:max-w-fit flex justify-center">
      <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-none md:rounded-none py-2 md:py-4 px-4 md:px-10 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.5)] flex flex-row items-center justify-center gap-4 md:gap-10 w-auto mx-auto">
        
        <!-- Animated Stat Section -->
        <div class="relative h-14 md:h-20 w-auto min-w-[280px] md:min-w-[360px] overflow-hidden">
          {slides.map((slide, i) => (
            <div class={`stat-slide absolute inset-0 flex items-center justify-start gap-3 md:gap-5 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] ${i === 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'}`} data-index={i}>
              <div class="bg-[var(--brand-highlight)] text-[var(--brand-primary)] font-black text-2xl md:text-4xl px-4 md:px-5 py-2 md:py-2.5 rounded-none md:rounded-none shadow-xl transform -rotate-3 shrink-0">
                {slide.statNumber}
              </div>
              <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <h3 class="text-white font-black text-sm md:text-xl uppercase tracking-wider drop-shadow-sm leading-tight whitespace-nowrap">{getLocationText(slide.statLabel)}</h3>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Persistent Controls -->
        <div class="flex flex-row items-center justify-center gap-3 md:gap-5 border-l border-white/20 pl-4 md:pl-8 w-auto">
          <div class="flex gap-4 md:gap-6">
            {slides.map((_, dotIndex) => (
              <button 
                class="hud-dot group relative flex items-center justify-center w-8 h-8 -m-2"
                data-index={dotIndex} 
                aria-label={`Slide ${dotIndex + 1}`}
              >
                <span class={`visual-dot w-2 h-2 md:w-2.5 md:h-2.5 rounded-none transition-all duration-300 ${dotIndex === 0 ? 'bg-[var(--brand-highlight)] scale-150 shadow-[0_0_10px_var(--brand-highlight)]' : 'bg-white/30 group-hover:bg-white/60'}`}></span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

</section>
) : (
<!-- SUBPAGE VARIANT -->
<section class="hero-cinematic relative w-full overflow-hidden min-h-[70vh] flex flex-col justify-center items-center bg-[var(--brand-primary)]">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    {subpageImage && isRemoteImage(subpageImage) ? (
      <Image
        src={subpageImage}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover scale-105"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        widths={[480, 800, 1200, 1920]}
        sizes="100vw"
        inferSize={true}
        format="webp"
        quality={80}
      />
    ) : subpageImage ? (
      <img
        src={subpageImage}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover scale-105"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        width="1920"
        height="1080"
      />
    ) : (
      <Image
        src={bg2Img}
        alt="HVAC background"
        format="avif"
        quality={85}
        widths={[480, 800, 1200, 1920]}
        sizes="100vw"
        class="absolute inset-0 w-full h-full object-cover scale-105"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        inferSize={true}
      />
    )}
  </div>

  <!-- Cinematic Vignette Overlays -->
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--brand-primary)]/80 via-transparent to-[var(--brand-primary)]/90 mix-blend-multiply z-[1]"></div>
  <div class="absolute inset-0 bg-black/30 z-[1]"></div>

  <!-- Center Text -->
  <div class="relative z-[2] container mx-auto px-6 flex-1 flex flex-col justify-center items-center text-center pt-32 pb-32">
    {badge && (
      <span class="mb-8 inline-flex items-center gap-3 px-6 py-2 bg-[var(--brand-highlight)] text-[var(--brand-primary)] font-black uppercase tracking-[0.2em] rounded-none text-sm shadow-xl">
        <span class="w-2.5 h-2.5 rounded-none bg-[var(--brand-primary)] animate-pulse"></span>
        {getLocationText(badge)}
      </span>
    )}
    
    <h1 class="hero-title text-5xl md:text-6xl lg:text-[5.5rem] font-black leading-[1.05] mb-6 uppercase tracking-tight text-white drop-shadow-2xl max-w-5xl">
      {subpageTitle && getLocationText(subpageTitle)}
    </h1>
    
    {subpageSubtitle && (
      <p class="hero-subtitle text-xl md:text-2xl leading-relaxed text-gray-200 font-medium max-w-3xl mx-auto drop-shadow-lg mb-10">
        {getLocationText(subpageSubtitle)}
      </p>
    )}
  </div>

  <!-- Bottom Glass Bar for Trust Indicators -->
  {trustIndicators && trustIndicators.length > 0 && (
    <div class="absolute bottom-8 left-0 right-0 z-[10] px-4 md:px-6">
      <div class="container mx-auto max-w-5xl">
        <div class="bg-white/10 backdrop-blur-lg border border-white/20 rounded-none p-5 lg:p-6 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)] flex flex-wrap justify-center items-center gap-6 lg:gap-12">
          {trustIndicators.map((indicator) => (
            <span class="inline-flex items-center gap-3 text-sm lg:text-base font-bold text-white uppercase tracking-wider drop-shadow-md">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--brand-highlight)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"/>
              </svg>
              {getLocationText(indicator)}
            </span>
          ))}
        </div>
      </div>
    </div>
  )}
</section>
)}

<style>
  /* Use CSS Grid stacking to easily overlap elements and maintain parent height dynamically */
  .text-slider-grid, .hud-slider-grid {
    display: grid;
    grid-template-areas: "stack";
  }
  .text-slide, .hud-slide {
    grid-area: stack;
  }

  /* Image gentle zoom effect on slider */
  .img-slide img {
    transform: scale(1.05);
    transition: transform 10s ease-out;
  }
  .img-slide.opacity-100 img {
    transform: scale(1);
  }

  /* Entrance animations for subpage */
  @keyframes slideUpFade {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-title { animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hero-subtitle { animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both; }

  @media (prefers-reduced-motion: reduce) {
    .text-slide, .hud-slide, .img-slide {
      transition: opacity 0.3s ease !important;
      transform: none !important;
    }
    .img-slide img { transform: none !important; transition: none !important; }
    .hero-title, .hero-subtitle { animation: none !important; }
  }
</style>

<script is:inline>
  var HERO_INTERVAL = 6000;
  var heroTimer;

  function initHeroSlider() {
    if (heroTimer) {
      clearInterval(heroTimer);
      heroTimer = undefined;
    }

    var textSlides = document.querySelectorAll('.text-slide');
    var imgSlides = document.querySelectorAll('.img-slide');
    var statSlides = document.querySelectorAll('.stat-slide');
    var dots = document.querySelectorAll('.hud-dot');
    var visualDots = document.querySelectorAll('.visual-dot');
    
    if (!textSlides.length || !imgSlides.length || !statSlides.length || !dots.length) return;

    var current = 0;

    function goTo(index) {
      // 1. Reset all states
      textSlides.forEach(s => {
        s.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
        s.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
      });
      imgSlides.forEach(s => s.classList.remove('opacity-100'));
      statSlides.forEach(s => {
        s.classList.remove('opacity-100', 'translate-y-0');
        s.classList.add('opacity-0', 'translate-y-8');
      });
      visualDots.forEach(d => {
        d.classList.remove('bg-[var(--brand-highlight)]', 'scale-150', 'shadow-[0_0_10px_var(--brand-highlight)]');
        d.classList.add('bg-white/30');
      });

      // 2. Update index
      current = index;

      // 3. Show current
      textSlides[current].classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
      textSlides[current].classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
      
      imgSlides[current].classList.add('opacity-100');
      imgSlides[current].classList.remove('opacity-0');
      
      statSlides[current].classList.add('opacity-100', 'translate-y-0');
      statSlides[current].classList.remove('opacity-0', 'translate-y-8');
      
      visualDots[current].classList.add('bg-[var(--brand-highlight)]', 'scale-150', 'shadow-[0_0_10px_var(--brand-highlight)]');
      visualDots[current].classList.remove('bg-white/30');

      resetTimer();
    }

    function resetTimer() {
      if (heroTimer) clearInterval(heroTimer);
      heroTimer = setInterval(function() { goTo((current + 1) % textSlides.length); }, HERO_INTERVAL);
    }

    dots.forEach(function(dot) { 
      dot.addEventListener('click', function() { 
        goTo(parseInt(dot.getAttribute('data-index'))); 
      }); 
    });

    // Start initial animation
    resetTimer();
  }

  initHeroSlider();
  document.addEventListener('astro:page-load', initHeroSlider);
</script>

