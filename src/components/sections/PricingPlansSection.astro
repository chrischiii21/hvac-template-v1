---
import { getLocationText } from "@/config/site"

interface Plan {
  ribbon: string;
  ribbonColor?: "great" | "better" | "best";
  title: string;
  price: string;
  period?: string;
  features: string[];
}

interface Props {
  title: string;
  description: string;
  plans: Plan[];
}

const { title: rawTitle, description: rawDescription, plans } = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);

const bestIndex = plans.findIndex(p => p.ribbonColor === "best");
---

<section class="pp-section relative bg-white py-16 md:py-28 lg:py-32 overflow-hidden">
  
  {/* Abstract Background Accents */}
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[var(--brand-primary)]/5 rounded-none blur-[140px] translate-x-1/3 -translate-y-1/3"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[var(--brand-highlight)]/5 rounded-none blur-[120px] -translate-x-1/4 translate-y-1/4"></div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">

    <!-- Cinematic Header -->
    <div class="pp-header mb-12 lg:mb-20 reveal-on-scroll">
      <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-[var(--brand-primary)]/5 rounded-none border border-[var(--brand-primary)]/10 mb-8">
        <span class="w-2.5 h-2.5 rounded-none bg-[var(--brand-highlight)] animate-pulse"></span>
        <span class="text-xs font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">Plans</span>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
        <div class="lg:col-span-7">
          <h2 class="text-4xl md:text-5xl lg:text-7xl font-black text-[var(--brand-primary)] uppercase tracking-tighter leading-[0.95] mb-0">
            {title}
          </h2>
        </div>
        <div class="lg:col-span-5">
          <div class="relative">
             <div class="absolute -left-8 top-0 bottom-0 w-1 bg-[var(--brand-highlight)] rounded-none hidden lg:block"></div>
             <p class="text-[1.05rem] text-[var(--brand-secondary)] lg:text-lg leading-relaxed font-medium" set:html={description} />
          </div>
        </div>
      </div>
    </div>

    <!-- Pricing Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-14 items-stretch max-w-7xl mx-auto">
      {plans.map((plan, i) => (
        <div 
          class={`reveal-on-scroll relative group flex flex-col p-10 lg:p-14 rounded-none transition-all duration-500 h-full bg-white
            ${i === bestIndex 
              ? 'border-2 border-[var(--brand-primary)] shadow-[0_40px_80px_-20px_rgba(var(--brand-primary-rgb),0.15)] z-20 md:scale-105' 
              : 'border border-gray-100 shadow-sm z-10 hover:border-[var(--brand-primary)]/30'
            } hover:-translate-y-2 hover:shadow-[0_50px_90px_-20px_rgba(0,0,0,0.1)]`}
          style={`transition-delay: ${i * 100}ms`}
        >
          {/* Ribbon */}
          <div class="mb-12">
            <span class={`inline-block px-8 py-2.5 rounded-none text-[0.65rem] font-black uppercase tracking-[0.25em] transition-all duration-500
              ${i === bestIndex 
                ? 'bg-[var(--brand-primary)] text-white shadow-lg shadow-[var(--brand-primary)]/20' 
                : 'bg-gray-50 text-[var(--brand-secondary)]/50 border border-gray-100 group-hover:bg-[var(--brand-primary)]/5 group-hover:text-[var(--brand-primary)] group-hover:border-[var(--brand-primary)]/10'
              }`}>
              {plan.ribbon}
            </span>
          </div>

          <div class="mb-10">
            <h3 class="text-2xl font-black text-[var(--brand-primary)] uppercase tracking-tight mb-4">{plan.title}</h3>
            <div class={`h-1.5 rounded-none transition-all duration-500 ${i === bestIndex ? 'bg-[var(--brand-highlight)] w-24' : 'bg-gray-100 w-12 group-hover:bg-[var(--brand-highlight)] group-hover:w-20'}`}></div>
          </div>

          {/* Price */}
          <div class="mb-14">
            <div class="flex items-baseline gap-1 group-hover:scale-105 transition-transform duration-500 origin-left">
              <span class={`text-5xl lg:text-7xl font-black tracking-tighter transition-colors ${i === bestIndex ? 'text-[var(--brand-primary)]' : 'text-[var(--brand-primary)]/80'}`}>
                {plan.price}
              </span>
              {plan.period && (
                <span class="text-xs font-bold text-[var(--brand-secondary)]/40 uppercase tracking-widest ml-1 mb-2">
                  {plan.period}
                </span>
              )}
            </div>
          </div>

          {/* Features List */}
          <div class="flex-1">
            <ul class="space-y-6">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-4 group/item">
                  <div class={`mt-1.5 w-1.5 h-1.5 rounded-none flex-shrink-0 transition-all duration-500
                    ${i === bestIndex ? 'bg-[var(--brand-highlight)] scale-125' : 'bg-[var(--brand-primary)]/20 group-hover:bg-[var(--brand-highlight)] group-hover:scale-125'}`}>
                  </div>
                  <span class={`text-[1.05rem] font-medium leading-relaxed transition-colors duration-500
                    ${i === bestIndex ? 'text-[var(--brand-primary)]' : 'text-[var(--brand-secondary)]/70 group-hover:text-[var(--brand-primary)]'}`}>
                    {feature}
                  </span>
                </li>
              ))}
            </ul>
          </div>

          {/* Subtle Bottom Accent for Spotlight Card */}
          {i === bestIndex && (
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-[var(--brand-primary)]/5 rounded-none blur-[100px] pointer-events-none -z-10"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1.2s cubic-bezier(0.2, 1, 0.2, 1);
  }
  
  .reveal-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initPricingAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  initPricingAnimations();
  document.addEventListener('astro:page-load', initPricingAnimations);
</script>

