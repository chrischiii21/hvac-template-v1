---
import { getLocationText } from "@/config/site"
import { Card, CardContent } from "@/components/ui/card"

interface Plan {
  ribbon: string;
  ribbonColor?: "great" | "better" | "best";
  title: string;
  price: string;
  period?: string;
  features: string[];
}

interface Props {
  title: string;
  description: string;
  plans: Plan[];
}

const { title: rawTitle, description: rawDescription, plans } = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);

const bestIndex = plans.findIndex(p => p.ribbonColor === "best");
---

<section class="pp-section">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">

    <!-- Header -->
    <div class="pp-header" data-animate="fade-up">
      <div class="pp-eyebrow">
        <span class="pp-eyebrow-text">Plans</span>
      </div>
      <h2 class="pp-title">{title}</h2>
      <div class="pp-divider"></div>
      <p class="pp-desc" set:html={description} />
    </div>

    <!-- Plans grid using React Card -->
    <div class="pp-grid" data-animate-stagger>
      {plans.map((plan, i) => (
        <Card className={`relative overflow-hidden group border-gray-100 transition-all duration-300 h-full ${i === bestIndex ? "border-[var(--brand-highlight)] shadow-[0_0_0_1px_var(--brand-highlight)] md:-translate-y-4 md:hover:-translate-y-5" : "hover:border-[var(--brand-highlight)] hover:-translate-y-1 hover:shadow-xl"}`}>
          {/* Top accent line sweep */}
          <span class={`absolute top-0 left-0 right-0 h-[4px] bg-[var(--brand-highlight)] z-10 transition-transform duration-500 origin-left ${i === bestIndex ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'}`}></span>

          {/* Ribbon */}
          <div class={`px-6 py-2.5 border-b border-gray-100 ${i === bestIndex ? 'bg-[var(--brand-primary)] text-[var(--brand-highlight)]' : 'bg-[var(--brand-tertiary)] text-[var(--brand-secondary)]'}`}>
            <span class="text-xs font-bold uppercase tracking-[0.15em]">{plan.ribbon}</span>
          </div>

          <CardContent className="relative flex flex-col p-8 md:p-10 h-full">
            <h3 class="text-sm font-bold uppercase tracking-[0.1em] text-[var(--brand-primary)] mb-4">{plan.title}</h3>

            {/* Price */}
            <div class="flex items-baseline gap-1 mb-5">
              <span class={`font-['Inter'] text-5xl font-black leading-none ${i === bestIndex ? 'text-[var(--brand-highlight)]' : 'text-[var(--brand-primary)]'}`}>{plan.price}</span>
              {plan.period && <span class="text-sm font-bold text-[var(--brand-secondary)]">{plan.period}</span>}
            </div>

            <div class="w-8 h-[3px] bg-[var(--brand-highlight)] mb-6 shadow-[0_0_10px_rgba(var(--brand-highlight-rgb),0.5)]"></div>

            {/* Features */}
            <ul class="flex flex-col gap-3">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed text-gray-600 font-medium">
                  <span class="w-1.5 h-1.5 bg-[var(--brand-highlight)] mt-1.5 flex-shrink-0 shadow-[0_0_5px_rgba(var(--brand-highlight-rgb),0.5)]"></span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </CardContent>
        </Card>
      ))}
    </div>
  </div>
</section>

<style>
  .pp-section {
    background: var(--background);
  }

  /* ─── Header ─── */
  .pp-header {
    text-align: center;
    margin-bottom: 3.5rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }
  .pp-eyebrow {
    margin-bottom: 1.25rem;
  }
  .pp-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }
  .pp-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .pp-title { font-size: 2.25rem; }
  }
  .pp-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin: 0 auto 1.25rem;
  }
  .pp-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Grid ─── */
  .pp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: end;
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .pp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .pp-grid {
      grid-template-columns: 1fr;
      max-width: 28rem;
    }
  }
</style>
