---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  benefits?: string[];
}

const { title: rawTitle, description: rawDescription, subtitle: rawSubtitle, benefits: rawBenefits = [] } = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const benefits = rawBenefits.map(getLocationText);
---

<section class="fi-section overflow-hidden">
  <!-- Dynamic Cinematic Background -->
  <div class="fi-bg-canvas">
    <div class="fi-mesh-gradient"></div>
    <div class="fi-grid-pattern"></div>
    <!-- Animated Glass Blobs -->
    <div class="fi-blob fi-blob-1"></div>
    <div class="fi-blob fi-blob-2"></div>
    <div class="fi-blob fi-blob-3"></div>
  </div>
  
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-24 md:py-36 relative z-10">
    <div class="fi-grid">
      
      <!-- Content Column -->
      <div class="fi-content-col" data-animate="fade-right">
        <div class="fi-eyebrow">
          <span class="fi-eyebrow-pill">
            <span class="fi-eyebrow-dot"></span>
            Financing
          </span>
        </div>
        
        <h2 class="fi-title">{title}</h2>
        
        <div class="fi-divider-group">
          <div class="fi-divider-line"></div>
          <div class="fi-divider-square"></div>
        </div>
        
        <div class="fi-desc-container">
          <p class="fi-desc" set:html={description} />
        </div>
      </div>

      <!-- Card Column -->
      <div class="fi-card-col" data-animate="fade-left" data-animate-delay="200">
        {subtitle && benefits.length > 0 && (
          <div class="fi-card">
            <!-- Inner Glass Glow -->
            <div class="fi-card-shimmer"></div>
            
            <div class="fi-card-inner">
              <div class="fi-card-header">
                <div class="fi-card-icon-wrapper">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                </div>
                <h3 class="fi-card-heading">{subtitle}</h3>
              </div>

              <div class="fi-benefits-list">
                {benefits.map((benefit) => (
                  <div class="fi-benefit-row">
                    <div class="fi-benefit-check-box">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <span class="fi-benefit-content">{benefit}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>

    </div>
  </div>
</section>

<style>
  .fi-section {
    position: relative;
    background: var(--brand-tertiary);
    min-height: 600px;
    display: flex;
    align-items: center;
  }

  /* ─── Background Canvas ─── */
  .fi-bg-canvas {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .fi-mesh-gradient {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 10% 20%, color-mix(in srgb, var(--brand-tertiary), white 20%) 0%, transparent 40%),
      radial-gradient(circle at 90% 80%, color-mix(in srgb, var(--brand-tertiary), black 10%) 0%, transparent 40%),
      var(--brand-tertiary);
  }

  .fi-grid-pattern {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
  }

  /* Animated Blobs */
  .fi-blob {
    position: absolute;
    border-radius: 0;
    filter: blur(80px);
    opacity: 0.4;
    z-index: 2;
    animation: blobFloat 20s infinite alternate cubic-bezier(0.45, 0, 0.55, 1);
  }
  .fi-blob-1 {
    width: 400px;
    height: 400px;
    background: white;
    top: -100px;
    left: -100px;
    animation-delay: 0s;
  }
  .fi-blob-2 {
    width: 300px;
    height: 300px;
    background: var(--brand-highlight);
    bottom: -50px;
    right: 10%;
    animation-delay: -5s;
    opacity: 0.2;
  }
  .fi-blob-3 {
    width: 250px;
    height: 250px;
    background: var(--brand-primary);
    top: 40%;
    left: 40%;
    animation-delay: -10s;
    opacity: 0.1;
  }

  @keyframes blobFloat {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(40px, 60px) scale(1.1); }
  }

  /* ─── Layout Grid ─── */
  .fi-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .fi-grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 6rem;
    }
  }

  /* ─── Content Column ─── */
  .fi-content-col {
    text-align: left;
  }

  .fi-eyebrow {
    margin-bottom: 1.5rem;
  }

  .fi-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
    color: white;
    border-radius: 0;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .fi-eyebrow-dot {
    width: 6px;
    height: 6px;
    background: var(--brand-highlight);
    border-radius: 0;
    box-shadow: 0 0 10px var(--brand-highlight);
  }

  .fi-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: var(--brand-primary);
    margin-bottom: 2rem;
  }

  .fi-divider-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .fi-divider-line {
    width: 60px;
    height: 4px;
    background: var(--brand-primary);
    border-radius: 0;
  }

  .fi-divider-square {
    width: 12px;
    height: 12px;
    background: var(--brand-highlight);
    transform: rotate(45deg);
  }

  .fi-desc {
    font-size: 1.125rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--brand-primary), black 20%);
    max-width: 32rem;
    font-weight: 500;
  }

  /* ─── Card Column ─── */
  .fi-card {
    position: relative;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 0;
    padding: 3rem 2rem;
    box-shadow: 
      0 30px 60px -12px rgba(0, 0, 0, 0.1),
      inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (min-width: 768px) {
    .fi-card {
      padding: 4rem 3.5rem;
    }
  }

  .fi-card:hover {
    transform: translateY(-10px) rotate(1deg);
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 40px 80px -15px rgba(0, 0, 0, 0.15);
  }

  .fi-card-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 200%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transform: skewX(-20deg);
    transition: 0.8s;
    pointer-events: none;
  }
  .fi-card:hover .fi-card-shimmer {
    left: 100%;
  }

  .fi-card-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .fi-card-icon-wrapper {
    width: 56px;
    height: 56px;
    background: var(--brand-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .fi-card-heading {
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-primary);
    line-height: 1.3;
  }

  .fi-benefits-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .fi-benefit-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: 0;
    transition: background 0.3s ease;
  }
  .fi-benefit-row:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .fi-benefit-check-box {
    width: 24px;
    height: 24px;
    background: var(--brand-highlight);
    color: var(--brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .fi-benefit-content {
    font-size: 1rem;
    color: var(--brand-primary);
    font-weight: 600;
    line-height: 1.4;
  }

  .fi-card-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    padding-top: 1.5rem;
  }

  .fi-footer-tag {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-primary);
    background: rgba(255, 255, 255, 0.5);
    padding: 0.35rem 0.75rem;
    border-radius: 0;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  /* ─── Animations ─── */
  @media (prefers-reduced-motion: reduce) {
    .fi-blob { animation: none; }
    .fi-card:hover { transform: none; }
  }
</style>


