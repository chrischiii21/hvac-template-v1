---
import Button from "../ui/Button.astro";
import { siteConfig, getLocationText } from "@/config/site";

interface Props {
  title: string;
  description: string;
  calloutText: string;
  phone?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title: rawTitle,
  description: rawDescription,
  calloutText: rawCalloutText,
  phone = siteConfig.contact.phoneFormatted,
  buttonText = "Sign Up Online",
  buttonHref = "/contact",
} = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const calloutText = getLocationText(rawCalloutText);
---

<section
  class="sb-section relative bg-[var(--brand-primary)] py-12 md:py-16 lg:py-20 overflow-hidden"
>
  {/* Cinematic Background Accents */}
  <div
    class="absolute top-0 right-0 w-[400px] h-[400px] bg-white/5 rounded-full blur-[100px] translate-x-1/4 -translate-y-1/4"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-[var(--brand-highlight)]/10 rounded-full blur-[80px] -translate-x-1/4 translate-y-1/4"
  >
  </div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center reveal-on-scroll"
    >
      {/* Content Area */}
      <div class="lg:col-span-7 xl:col-span-8 text-center lg:text-left">
        <div
          class="inline-flex items-center gap-3 px-4 py-1.5 bg-white/5 backdrop-blur-xl rounded-full border border-white/10 mb-6"
        >
          <span
            class="w-2 h-2 rounded-full bg-[var(--brand-highlight)] animate-pulse"
          ></span>
          <span
            class="text-[0.6rem] font-black text-white uppercase tracking-[0.2em]"
            >{calloutText}</span
          >
        </div>

        <h2
          class="text-3xl md:text-4xl lg:text-5xl font-black text-white uppercase tracking-tighter leading-tight mb-4"
        >
          {title}
        </h2>

        <p
          class="text-base md:text-lg text-white/60 font-medium leading-relaxed max-w-2xl mx-auto lg:mx-0"
          set:html={description}
        />
      </div>

      {/* Action Area */}
      <div
        class="lg:col-span-5 xl:col-span-4 flex flex-col items-center lg:items-end justify-center gap-4"
      >
        <Button
          href={`tel:${phone.replace(/[^0-9]/g, "")}`}
          variant="glass"
          rounded="2xl"
          size="lg"
          className="w-full sm:w-[300px]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-[var(--brand-highlight)]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            ><path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
            ></path></svg
          >
          Call {phone}
        </Button>

        <Button
          href={buttonHref}
          variant="white"
          rounded="2xl"
          size="lg"
          className="w-full sm:w-[300px]"
        >
          {buttonText}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.2, 1, 0.2, 1);
  }

  .reveal-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initSignupAnimations() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-revealed");
          }
        });
      },
      { threshold: 0.1 },
    );

    document
      .querySelectorAll(".reveal-on-scroll")
      .forEach((el) => observer.observe(el));
  }

  initSignupAnimations();
  document.addEventListener("astro:page-load", initSignupAnimations);
</script>
