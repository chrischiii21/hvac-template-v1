---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface FeatureItem {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  featuresTitle?: string;
  features?: FeatureItem[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  image?: string;
  imageAlt?: string;
}

const {
  badge,
  title: rawTitle,
  titleHighlight: rawTitleHighlight,
  description: rawDescription,
  featuresTitle,
  features: rawFeatures = [],
  buttonText,
  buttonHref,
  imagePosition = "left",
  image,
  imageAlt = "Section image"
} = Astro.props;

const title = getLocationText(rawTitle);
const titleHighlight = rawTitleHighlight ? getLocationText(rawTitleHighlight) : undefined;
const description = getLocationText(rawDescription);
const features = rawFeatures.map(f => ({
  ...f,
  title: getLocationText(f.title),
  description: getLocationText(f.description),
}));

const isRight = imagePosition === "right";
---

<section class="csa-balanced relative overflow-hidden py-16 md:py-24">
  <!-- Subtle Background Pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none">
    <div class="h-full w-full bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:40px_40px]"></div>
  </div>

  <div class="container mx-auto px-6 md:px-12">
    <div class:list={["csa-main-wrap", { "csa-main-wrap--reversed": isRight }]}>
      
      <!-- Visual Half -->
      <div class="csa-visual-half" data-animate="fade-up">
        <div class="csa-image-container h-full">
          {image ? (
            <Image
              src={image}
              alt={imageAlt}
              class="csa-image-fit"
              width={1000}
              height={1000}
              format="webp"
              quality={85}
            />
          ) : (
            <div class="csa-placeholder"><span>Image</span></div>
          )}
          <!-- Integrated Overlays to fill space -->
          <div class="csa-overlay-gradient"></div>
          {badge && (
            <div class="csa-visual-badge">
              <span class="csa-v-badge-dot"></span>
              {badge}
            </div>
          )}
        </div>
      </div>

      <!-- Content Half -->
      <div class="csa-content-half" data-animate="fade-up" data-animate-delay="100">
        <div class="csa-content-inner">
          <h2 class="csa-title">
            {title}{" "}
            {titleHighlight && (
              <span class="csa-highlight">{titleHighlight}</span>
            )}
          </h2>

          <p class="csa-description" set:html={description} />

          <!-- High-Density Features Grid -->
          {features.length > 0 && (
            <div class="csa-features-block">
              {featuresTitle && (
                <h3 class="csa-f-title">{featuresTitle}</h3>
              )}
              <div class="csa-f-grid">
                {features.map((feature, i) => (
                  <div class="csa-f-item">
                    <div class="csa-f-icon-box">
                      <span class="csa-f-number">{String(i + 1).padStart(2, '0')}</span>
                    </div>
                    <div class="csa-f-text">
                      <h4 class="csa-f-label">{feature.title}</h4>
                      <p class="csa-f-desc" set:html={feature.description} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {buttonHref && (
            <div class="csa-action-wrap">
              <a href={buttonHref} class="csa-block-btn">
                <span>{buttonText || "Read More"}</span>
                <div class="csa-btn-glow"></div>
              </a>
            </div>
          )}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .csa-balanced {
    background: #0a0a0f;
    color: #fff;
  }

  /* ─── Layout ─── */
  .csa-main-wrap {
    display: grid;
    grid-template-columns: 1fr;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 2.5rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 1024px) {
    .csa-main-wrap {
      grid-template-columns: 1.1fr 0.9fr;
      min-height: 700px;
    }
    .csa-main-wrap--reversed .csa-visual-half { order: 2; }
    .csa-main-wrap--reversed .csa-content-half { order: 1; }
  }

  /* ─── Visual Half ─── */
  .csa-visual-half { position: relative; overflow: hidden; }
  .csa-image-container { position: relative; width: 100%; height: 100%; }
  .csa-image-fit { width: 100%; height: 100%; object-fit: cover; transition: transform 1.5s ease; }
  .csa-main-wrap:hover .csa-image-fit { transform: scale(1.05); }
  
  .csa-overlay-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(to right, #0a0a0f 0%, transparent 20%, transparent 80%, #0a0a0f 100%);
    pointer-events: none;
  }
  @media (max-width: 1023px) {
    .csa-overlay-gradient { background: linear-gradient(to bottom, transparent 60%, #0a0a0f 100%); }
  }

  .csa-visual-badge {
    position: absolute; top: 2rem; left: 2rem;
    background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(10px);
    padding: 0.6rem 1.25rem; border-radius: 99px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.75rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.2em; color: var(--brand-highlight);
    display: flex; align-items: center; gap: 0.75rem;
  }
  .csa-v-badge-dot { width: 8px; height: 8px; background: var(--brand-highlight); border-radius: 50%; box-shadow: 0 0 10px var(--brand-highlight); }

  /* ─── Content Half ─── */
  .csa-content-half {
    padding: 3rem 2rem;
    display: flex; align-items: center;
  }
  @media (min-width: 1024px) {
    .csa-content-half { padding: 5rem 4rem; }
  }
  .csa-content-inner { width: 100%; }

  .csa-title {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 900; line-height: 1; color: #fff;
    margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: -0.03em;
  }
  .csa-highlight { color: var(--brand-highlight); }

  .csa-description {
    font-size: 1.05rem; line-height: 1.6; color: rgba(255, 255, 255, 0.5);
    margin-bottom: 3rem; font-weight: 500;
  }

  /* ─── Features Grid ─── */
  .csa-features-block {
    margin-bottom: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  .csa-f-title {
    font-size: 0.8rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.25em; color: var(--brand-highlight);
    margin-bottom: 2rem; opacity: 0.8;
  }
  .csa-f-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) {
    .csa-f-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .csa-f-item { display: flex; gap: 1.25rem; }
  .csa-f-icon-box {
    flex-shrink: 0; width: 42px; height: 42px;
    background: rgba(255, 255, 255, 0.05); border-radius: 0.75rem;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .csa-f-number { font-size: 0.85rem; font-weight: 900; color: var(--brand-highlight); }
  
  .csa-f-label { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 0.4rem; }
  .csa-f-desc { font-size: 0.85rem; line-height: 1.5; color: rgba(255, 255, 255, 0.4); font-weight: 500; }

  /* ─── Button ─── */
  .csa-block-btn {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 1.25rem 3rem; background: var(--brand-highlight);
    color: var(--brand-primary); border-radius: 1rem;
    font-weight: 900; font-size: 0.9rem; text-transform: uppercase;
    letter-spacing: 0.15em; text-decoration: none; overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .csa-btn-glow {
    position: absolute; inset: 0;
    background: linear-gradient(45deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%);
    transform: translateX(-100%); transition: transform 0.6s ease;
  }
  .csa-block-btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -10px color-mix(in srgb, var(--brand-highlight), transparent 60%);
  }
  .csa-block-btn:hover .csa-btn-glow { transform: translateX(100%); }

  /* ─── Mobile ─── */
  @media (max-width: 768px) {
    .csa-main-wrap { border-radius: 1.5rem; }
    .csa-visual-half { min-height: 300px; }
    .csa-title { font-size: 2.25rem; }
    .csa-f-grid { gap: 1.5rem; }
  }
</style>

