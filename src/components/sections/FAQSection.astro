---
import Button from "../ui/Button.astro";
import { getLocationText } from "@/config/site";

interface FAQItem {
  question: string;
  answer?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  faqs: FAQItem[];
}

const {
  title: rawTitle,
  subtitle: rawSubtitle,
  badge = "FAQ",
  faqs: rawFaqs,
} = Astro.props;

const title = getLocationText(rawTitle);
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const faqs = rawFaqs.map((faq) => ({
  ...faq,
  question: getLocationText(faq.question),
  answer: faq.answer ? getLocationText(faq.answer) : undefined,
}));
---

<section class="fq-section relative overflow-hidden bg-white py-20 lg:py-28">
  <!-- Cinematic Background Accents -->
  <div
    class="absolute top-0 right-0 w-[600px] h-[600px] bg-[var(--brand-primary)]/5 rounded-none blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[var(--brand-highlight)]/5 rounded-none blur-[100px] translate-y-1/3 -translate-x-1/4 pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    <!-- Unified Dynamic Header -->
    <div class="mb-12 lg:mb-16 reveal-on-scroll">
      {
        badge && (
          <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-[var(--brand-primary)]/5 rounded-none border border-[var(--brand-primary)]/10 mb-8">
            <span class="w-2.5 h-2.5 rounded-none bg-[var(--brand-highlight)] animate-pulse" />
            <span class="text-xs font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">
              {badge}
            </span>
          </div>
        )
      }
      <h2
        class="text-4xl md:text-5xl lg:text-7xl font-black text-[var(--brand-primary)] uppercase tracking-tighter leading-[0.95] max-w-4xl"
        set:html={title}
      />
      {
        subtitle && (
          <p
            class="text-[0.9rem] lg:text-[1.05rem] text-[var(--brand-secondary)] font-medium leading-relaxed mt-6 max-w-2xl"
            set:html={subtitle}
          />
        )
      }
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
      <!-- Left Column: Premium Accordion List -->
      <div
        class="lg:col-span-8 flex flex-col gap-4 reveal-on-scroll"
        data-animate-delay="100"
      >
        {
          faqs.map((faq, index) => (
            <div class="fq-item group bg-white rounded-none lg:rounded-none border border-gray-100 shadow-[0_10px_30px_-15px_rgba(0,0,0,0.05)] transition-all duration-700 hover:border-[var(--brand-highlight)] hover:shadow-2xl hover:shadow-black/5 overflow-hidden">
              <button
                class="fq-trigger w-full flex items-center justify-between gap-6 p-6 lg:p-8 text-left cursor-pointer"
                aria-expanded="false"
                aria-controls={`fq-panel-${index}`}
                id={`fq-btn-${index}`}
              >
                <div class="flex items-center gap-6 lg:gap-8">
                  <span class="text-[0.65rem] lg:text-[0.75rem] font-black text-[var(--brand-primary)]/20 uppercase tracking-[0.2em] transition-colors duration-500 group-hover:text-[var(--brand-highlight)]">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span class="text-lg lg:text-xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-tight transition-transform duration-500 group-hover:translate-x-1">
                    {faq.question}
                  </span>
                </div>
                <div class="fq-icon w-9 h-9 lg:w-11 lg:h-11 rounded-none border border-gray-100 flex items-center justify-center text-[var(--brand-primary)] transition-all duration-700 group-hover:border-[var(--brand-highlight)] group-hover:bg-[var(--brand-highlight)] group-hover:text-white">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 lg:w-5 lg:h-5 transition-transform duration-700"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </div>
              </button>
              <div
                class="fq-panel max-h-0 overflow-hidden transition-all duration-700 ease-[cubic-bezier(0.25,1,0.3,1)]"
                id={`fq-panel-${index}`}
                role="region"
                aria-labelledby={`fq-btn-${index}`}
              >
                <div class="px-6 lg:px-8 pb-8 ml-0 lg:ml-16">
                  <div class="h-1 w-10 bg-[var(--brand-highlight)] mb-6 rounded-none opacity-30" />
                  <div
                    class="text-[0.9rem] lg:text-[1.05rem] text-[var(--brand-secondary)] font-medium leading-[1.6] max-w-2xl"
                    set:html={faq.answer}
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Right Column: Cinematic Call-to-Action Card -->
      <div
        class="lg:col-span-4 lg:sticky lg:top-32 reveal-on-scroll"
        data-animate-delay="200"
      >
        <div
          class="group relative overflow-hidden rounded-none lg:rounded-none bg-[var(--brand-primary)] p-8 lg:p-10 shadow-2xl"
        >
          <!-- Decorative Elements -->
          <div
            class="absolute inset-0 bg-gradient-to-br from-[var(--brand-primary)] to-black opacity-50"
          >
          </div>
          <div
            class="absolute -right-16 -bottom-16 w-64 h-64 bg-[var(--brand-highlight)]/10 rounded-none blur-[80px] group-hover:bg-[var(--brand-highlight)]/20 transition-colors duration-700"
          >
          </div>

          <div class="relative z-10">
            <div
              class="w-12 h-12 bg-white/5 border border-white/10 rounded-none flex items-center justify-center text-[var(--brand-highlight)] mb-8 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </div>

            <h3
              class="text-2xl lg:text-3xl font-black text-white uppercase tracking-tight leading-tight mb-4"
            >
              Have <br /><span class="text-[var(--brand-highlight)]"
                >questions?</span
              >
            </h3>

            <p
              class="text-white/40 text-[0.85rem] lg:text-[0.9rem] font-medium leading-relaxed mb-8"
            >
              We're here to help. If you don't find your answer below, reach out
              to our team directly.
            </p>

            <Button
              href="/contact"
              variant="white"
              rounded-none="2xl"
              size="lg"
              className="w-full"
            >
              Contact Us
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: all 1s cubic-bezier(0.25, 1, 0.3, 1);
  }

  .reveal-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .fq-item.is-open {
    border-color: var(--brand-highlight);
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.08);
  }

  .fq-item.is-open .fq-icon {
    background: var(--brand-primary);
    border-color: var(--brand-primary);
    color: white;
    transform: rotate(45deg);
  }

  .fq-item.is-open .fq-panel {
    max-height: 1000px;
  }
</style>

<script>
  function initFAQ() {
    document.querySelectorAll<HTMLElement>(".fq-item").forEach((item) => {
      const trigger = item.querySelector<HTMLButtonElement>(".fq-trigger");
      if (!trigger) return;
      if (trigger.dataset.init === "true") return;
      trigger.dataset.init = "true";

      trigger.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");

        if (isOpen) {
          item.classList.remove("is-open");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          item.classList.add("is-open");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );

    document
      .querySelectorAll(".reveal-on-scroll")
      .forEach((el) => observer.observe(el));
  }

  initFAQ();
  document.addEventListener("astro:page-load", initFAQ);
</script>

