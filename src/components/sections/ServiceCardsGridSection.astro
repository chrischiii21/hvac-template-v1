---
interface ServiceCard {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: ServiceCard[];
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  categories: ServiceCategory[];
}

const { badge = "OUR SERVICES", title, description, categories } = Astro.props;

// Balanced category colors
const panelColors = [
  "from-blue-50/20 to-white",
  "from-orange-50/20 to-white",
  "from-green-50/20 to-white",
  "from-purple-50/20 to-white",
  "from-gray-50/20 to-white",
];
---

<section class="svc-section relative overflow-hidden bg-[#fafafa] pt-24 pb-8 lg:pt-32 lg:pb-12">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    
    <!-- Balanced Header -->
    <div class="mb-16 lg:mb-24" data-animate="fade-up">
      <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-[var(--brand-primary)]/5 rounded-full border border-[var(--brand-primary)]/10 shadow-sm mb-8">
        <span class="w-2.5 h-2.5 rounded-full bg-[var(--brand-highlight)] animate-pulse"></span>
        <span class="text-xs font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">{badge}</span>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-end">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-[1.0] mb-0">
          {title}
        </h2>
        <div class="text-gray-500 text-lg font-medium leading-relaxed max-w-xl" set:html={description} />
      </div>
    </div>

    <!-- Click-Only Architectural Accordion -->
    <div class="flex flex-col lg:flex-row gap-4 lg:gap-5 h-auto lg:h-[640px] items-stretch" id="accordion-container">
      {categories.map((category, index) => (
        <div 
          class={`svc-panel group relative flex-grow transition-all duration-700 ease-[cubic-bezier(0.25,1,0.3,1)] overflow-hidden rounded-[2.5rem] lg:rounded-[3rem] border border-gray-100 bg-white shadow-sm hover:border-[var(--brand-highlight)]/40 cursor-pointer ${index === 0 ? 'is-active' : ''}`}
          data-index={index}
          data-accordion-panel
        >
          <!-- Gradient Background Base -->
          <div class={`absolute inset-0 bg-gradient-to-br transition-opacity duration-700 ${panelColors[index % panelColors.length]} panel-overlay opacity-0`}></div>
          
          <!-- Collapsed Label (Visible when not active) -->
          <div class="collapsed-label absolute inset-0 flex flex-col items-center justify-between py-16 transition-opacity duration-500">
            <span class="text-2xl font-black text-[var(--brand-primary)]/10">0{index + 1}</span>
            <h3 class="font-black text-[var(--brand-primary)] uppercase tracking-[0.45em] rotate-180 [writing-mode:vertical-lr] text-[0.75rem] lg:text-[0.8rem] opacity-60 group-hover:opacity-100 transition-opacity">
              {category.title}
            </h3>
            <div class="w-1.5 h-1.5 rounded-full bg-gray-200"></div>
          </div>

          <!-- Mobile Header (Always visible on mobile) -->
          <div class="lg:hidden flex items-center justify-between p-7 relative z-10 border-b border-gray-50">
            <div class="flex items-center gap-4">
              <span class="text-xl font-black text-[var(--brand-primary)]/10">0{index + 1}</span>
              <h3 class="text-sm font-black text-[var(--brand-primary)] uppercase tracking-widest">{category.title}</h3>
            </div>
            <div class="w-9 h-9 rounded-full bg-gray-50 flex items-center justify-center transition-transform duration-500 mobile-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>

          <!-- Expanded Content -->
          <div class="expanded-content relative h-full p-10 lg:p-16 flex flex-col opacity-0 translate-y-8 transition-all duration-700 pointer-events-none overflow-hidden">
            
            <!-- Internal Header -->
            <div class="hidden lg:flex items-center justify-between mb-12 border-b border-gray-100 pb-8">
              <div class="flex items-center gap-8">
                <span class="text-6xl font-black text-[var(--brand-primary)]/5 leading-none">0{index + 1}</span>
                <h3 class="text-3xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-none">{category.title}</h3>
              </div>
              <div class="w-11 h-11 bg-white border border-gray-100 rounded-full flex items-center justify-center text-[var(--brand-primary)] shadow-sm">
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
              </div>
            </div>

            <!-- Balanced Service Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10 lg:overflow-y-auto lg:custom-scrollbar lg:pr-6">
              {category.services.map((service) => (
                <div class="service-item group/service flex gap-6">
                  <div class="flex-shrink-0 w-13 h-13 bg-white rounded-2xl flex items-center justify-center text-[var(--brand-primary)] shadow-sm border border-gray-100 transition-all duration-500 group-hover/service:bg-[var(--brand-primary)] group-hover/service:text-white">
                    <div class="w-6.5 h-6.5" set:html={service.icon} />
                  </div>
                  <div class="flex-grow">
                    <h4 class="font-black text-[var(--brand-primary)] uppercase tracking-tight text-lg mb-2 group-hover/service:text-[var(--brand-highlight)] transition-colors">
                      {service.title}
                    </h4>
                    <p class="text-gray-500 text-sm font-medium leading-relaxed opacity-80" set:html={service.description} />
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #eee; border-radius: 10px; }

  @media (min-width: 1024px) {
    /* Base State: Static */
    .svc-panel {
      flex: 1;
    }

    /* ONLY Active State (Triggered by Click) */
    .svc-panel.is-active {
      flex: 7;
      cursor: default;
    }
    .svc-panel.is-active .expanded-content {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      transition-delay: 300ms;
    }
    .svc-panel.is-active .collapsed-label {
      opacity: 0;
      pointer-events: none;
    }
    .svc-panel.is-active .panel-overlay {
      opacity: 1;
    }

    /* Subtlest Hover Effect (No expansion) */
    .svc-panel:not(.is-active):hover {
      background: #fff;
      box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
    }
  }

  /* --- Mobile Stacked Accordion --- */
  @media (max-width: 1023px) {
    .svc-panel {
      flex: none;
      height: auto;
      max-height: 85px;
      transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      margin-bottom: 0.75rem;
    }
    .svc-panel.is-active {
      max-height: 2500px;
    }
    .svc-panel.is-active .expanded-content {
      opacity: 1;
      padding-top: 1.5rem;
      pointer-events: auto;
    }
    .svc-panel.is-active .panel-overlay {
      opacity: 1;
    }
    .svc-panel.is-active .mobile-toggle-icon {
      transform: rotate(180deg);
      background: var(--brand-primary);
      color: white;
    }
    .collapsed-label {
      display: none;
    }
  }
</style>

<script>
  const panels = document.querySelectorAll<HTMLElement>('[data-accordion-panel]');

  panels.forEach((panel) => {
    panel.addEventListener('click', () => {
      const isActive = panel.classList.contains('is-active');
      
      // Close all others
      panels.forEach((p) => p.classList.remove('is-active'));
      
      // Open clicked
      if (!isActive) {
        panel.classList.add('is-active');
      }
    });
  });
</script>
