---
interface ServiceCard {
  title: string;
  description: string;
  icon?: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: ServiceCard[];
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  categories: ServiceCategory[];
}

const { badge = "OUR SERVICES", title, description, categories } = Astro.props;

// --- Icon Logic ---
const serviceIcons = [
  { keywords: ['kitchen'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2" /><path d="M7 2v20" /><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7" /></svg>` },
  { keywords: ['bathroom', 'bath'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5" /><line x1="10" y1="5" x2="8" y2="7" /><line x1="2" y1="12" x2="22" y2="12" /><line x1="7" y1="19" x2="7" y2="21" /><line x1="17" y1="19" x2="17" y2="21" /></svg>` },
  { keywords: ['leak detection', 'leak repair', 'leak prevention', 'leak'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z" /><path d="M9.5 15.5a3 3 0 0 0 4.5 2" /></svg>` },
  { keywords: ['water heater', 'water heating'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z" /><circle cx="12" cy="17" r="1" /></svg>` },
  { keywords: ['drain', 'sewer', 'hydro jetting', 'jetting'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3" /><path d="M18.5 5.5 16.4 7.6" /><path d="M21 12h-3" /><path d="M18.5 18.5 16.4 16.4" /><path d="M12 21v-3" /><path d="M5.5 18.5 7.6 16.4" /><path d="M3 12h3" /><path d="M5.5 5.5 7.6 7.6" /><circle cx="12" cy="12" r="4" /></svg>` },
  { keywords: ['gas', 'gas line', 'gas piping'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" /></svg>` },
  { keywords: ['backflow', 'filtration', 'filter', 'purification', 'purif', 'indoor air', 'air quality'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z" /></svg>` },
  { keywords: ['maintenance', 'preventative', 'appliance', 'tune-up', 'tune up'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" /><circle cx="12" cy="12" r="3" /></svg>` },
  { keywords: ['pipe', 'repiping', 'repipe', 'sewer line', 'trenchless'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>` },
  { keywords: ['building', 'commercial', 'green', 'eco'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18" /><path d="M5 21V7l8-4v18" /><path d="M19 21V11l-6-4" /><path d="M9 9v.01" /><path d="M9 12v.01" /><path d="M9 15v.01" /></svg>` },
  { keywords: ['ac', 'air conditioning', 'cooling', 'cool'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/><circle cx="12" cy="12" r="3"/></svg>` },
  { keywords: ['heat', 'furnace', 'boiler', 'warm'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z" /><circle cx="12" cy="17" r="1" /></svg>` },
  { keywords: ['thermostat', 'smart'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" /><circle cx="12" cy="14" r="4" /><path d="M12 6v4" /></svg>` },
  { keywords: ['mini-split', 'ductless', 'split'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="8" rx="1" /><path d="M12 12v4" /><path d="M8 16h8" /><path d="M6 20h12" /></svg>` },
  { keywords: ['install', 'replacement', 'replace'], icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>` },
];

const fallbackIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>`;

function getIconForService(title: string, providedIcon?: string): string {
  if (providedIcon && providedIcon.trim().length > 10) return providedIcon;
  const lower = title.toLowerCase();
  for (const entry of serviceIcons) {
    if (entry.keywords.some((kw) => lower.includes(kw))) return entry.icon;
  }
  return fallbackIcon;
}

// Balanced category colors
const panelColors = [
  "from-blue-50/20 to-white",
  "from-orange-50/20 to-white",
  "from-green-50/20 to-white",
  "from-purple-50/20 to-white",
  "from-gray-50/20 to-white",
];
---

<section class="svc-section relative overflow-hidden bg-[#fafafa] pt-24 pb-8 lg:pt-32 lg:pb-12">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    
    <div class="mb-16 lg:mb-24 reveal-on-scroll">
      <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-[var(--brand-primary)]/5 rounded-none border border-[var(--brand-primary)]/10 shadow-sm mb-8">
        <span class="w-2.5 h-2.5 rounded-none bg-[var(--brand-highlight)] animate-pulse"></span>
        <span class="text-xs font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">{badge}</span>
      </div>
      
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-end">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-[1.0] mb-0">
          {title}
        </h2>
        <div class="text-gray-500 text-lg font-medium leading-relaxed max-w-xl" set:html={description} />
      </div>
    </div>

    <!-- Click-Only Architectural Accordion -->
    <div class="accordion-container flex flex-col lg:flex-row gap-4 lg:gap-5 h-auto lg:h-[640px] items-stretch">
      {categories.map((category, index) => (
        <div 
          class:list={[
            "svc-panel group relative flex-grow transition-all duration-700 ease-[cubic-bezier(0.25,1,0.3,1)] overflow-hidden rounded-none lg:rounded-none border border-gray-100 bg-white shadow-sm hover:border-[var(--brand-highlight)]/40 cursor-pointer",
            { "is-active": index === 0 }
          ]}
          data-index={index}
          data-accordion-panel
        >
          <!-- Gradient Background Base -->
          <div class:list={["absolute inset-0 bg-gradient-to-br transition-opacity duration-700 panel-overlay opacity-0", panelColors[index % panelColors.length]]}></div>
          
          <!-- Collapsed Label -->
          <div class="hidden lg:flex collapsed-label absolute inset-0 flex-col items-center justify-between py-16 transition-opacity duration-500" data-accordion-trigger>
            <span class="text-2xl font-black text-[var(--brand-primary)]/10">0{index + 1}</span>
            <h3 class="font-black text-[var(--brand-primary)] uppercase tracking-[0.45em] rotate-180 [writing-mode:vertical-lr] text-[0.75rem] lg:text-[0.8rem] opacity-60 group-hover:opacity-100 transition-opacity">
              {category.title}
            </h3>
            <div class="w-1.5 h-1.5 rounded-none bg-gray-200"></div>
          </div>

          <!-- Mobile Header -->
          <div class="lg:hidden flex items-center justify-between p-8 relative z-10 border-b border-gray-50" data-accordion-trigger>
            <div class="flex items-center gap-5">
              <span class="text-xl font-black text-[var(--brand-primary)]/10">0{index + 1}</span>
              <h3 class="text-[0.75rem] font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">{category.title}</h3>
            </div>
            <div class="w-10 h-10 rounded-none bg-gray-50 flex items-center justify-center transition-transform duration-500 mobile-toggle-icon">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>

          <!-- Expanded Content -->
          <div class="expanded-content relative h-full p-8 lg:p-16 flex flex-col opacity-0 translate-y-8 transition-all duration-700 pointer-events-none overflow-hidden">
            <div class="hidden lg:flex items-center justify-between mb-12 border-b border-gray-100 pb-8" data-accordion-trigger>
              <div class="flex items-center gap-8">
                <span class="text-6xl font-black text-[var(--brand-primary)]/5 leading-none">0{index + 1}</span>
                <h3 class="text-3xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-none">{category.title}</h3>
              </div>
              <div class="w-11 h-11 bg-white border border-gray-100 rounded-none flex items-center justify-center text-[var(--brand-primary)] shadow-sm transition-colors group-hover:border-[var(--brand-highlight)]/30">
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 lg:gap-y-10 lg:overflow-y-auto lg:custom-scrollbar lg:pr-6 pb-4">
              {category.services.map((service) => (
                <a href={service.href || "#"} class="service-item group/service flex gap-5 lg:gap-6 no-underline transition-all duration-300 hover:translate-x-1">
                  <div class="flex-shrink-0 w-12 h-12 lg:w-13 lg:h-13 bg-white rounded-none lg:rounded-none flex items-center justify-center text-[var(--brand-primary)] shadow-sm border border-gray-100 transition-all duration-500 group-hover/service:bg-[var(--brand-primary)] group-hover/service:text-white group-hover/service:border-[var(--brand-primary)] group-hover/service:shadow-md">
                    <div class="w-6 h-6 lg:w-6.5 lg:h-6.5" set:html={getIconForService(service.title, service.icon)} />
                  </div>
                  <div class="flex-grow pt-1">
                    <h4 class="font-black text-[var(--brand-primary)] uppercase tracking-tight text-[0.95rem] lg:text-lg mb-1.5 group-hover/service:text-[var(--brand-highlight)] transition-colors">
                      {service.title}
                    </h4>
                    <p class="text-xs lg:text-sm text-gray-500 font-medium leading-relaxed opacity-80" set:html={service.description} />
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #eee; border-radius: 0; }

  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1.2s cubic-bezier(0.25, 1, 0.3, 1);
  }
  .reveal-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 1024px) {
    .svc-panel { 
      flex: 1 !important; 
      transition: flex 0.7s cubic-bezier(0.25, 1, 0.3, 1), background 0.3s, box-shadow 0.3s;
    }
    
    .svc-panel.is-active { 
      flex: 7 !important; 
      cursor: default; 
    }
    
    .svc-panel.is-active .expanded-content { 
      opacity: 1 !important; 
      transform: translateY(0) !important; 
      pointer-events: auto !important; 
      transition-delay: 300ms; 
    }
    
    .svc-panel.is-active .collapsed-label { 
      opacity: 0 !important; 
      pointer-events: none; 
    }
    
    .svc-panel.is-active .panel-overlay { 
      opacity: 1 !important; 
    }
  }

  @media (max-width: 1023px) {
    .svc-panel { flex: none; height: auto; max-height: 85px; transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1); margin-bottom: 0.75rem; }
    .svc-panel.is-active { max-height: 2500px; }
    .svc-panel.is-active .expanded-content { opacity: 1 !important; padding-top: 1.5rem !important; pointer-events: auto !important; transform: none !important; }
    .svc-panel.is-active .panel-overlay { opacity: 1 !important; }
    .svc-panel.is-active .mobile-toggle-icon { transform: rotate(180deg); background: var(--brand-primary); color: white; }
    .collapsed-label { display: none; }
  }
</style>

<script>
  function initSvcSection() {
    // 1. Accordion Logic
    const containers = document.querySelectorAll('.accordion-container');
    containers.forEach((container) => {
      // Remove any existing listeners first to prevent duplicates
      const newContainer = container.cloneNode(true);
      container.parentNode.replaceChild(newContainer, container);

      newContainer.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const panel = target.closest('[data-accordion-panel]');
        if (!panel) return;

        const isActive = panel.classList.contains('is-active');
        const trigger = target.closest('[data-accordion-trigger]');
        
        // If it's a link click inside an active panel, let it handle the navigation
        if (isActive && target.closest('a')) return;

        // Accordion behavior:
        // 1. If panel is closed -> Open it and close others
        // 2. If panel is open and click is on a trigger (header) -> Close it
        if (!isActive) {
          const allPanels = newContainer.querySelectorAll('[data-accordion-panel]');
          allPanels.forEach((p) => p.classList.remove('is-active'));
          panel.classList.add('is-active');
        } else if (trigger) {
          panel.classList.remove('is-active');
        }
      });
    });

    // 2. Reveal Animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  // Initial load
  initSvcSection();
  
  // Astro View Transitions Support
  document.addEventListener('astro:page-load', initSvcSection);
  document.addEventListener('astro:after-swap', initSvcSection);
</script>

