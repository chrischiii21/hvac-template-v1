---
import { getLocationText } from "@/config/site"

interface Item {
  title: string;
  text?: string;
  href?: string;
  icon?: string;
  image?: string;
}

interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  items: Item[];
  variant?: "plans" | "services" | "features";
}

const { badge, title: rawTitle, subtitle: rawSubtitle, items: rawItems, variant = "plans" } = Astro.props;

const title = getLocationText(rawTitle);
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
const items = rawItems.map(item => ({
  ...item,
  title: getLocationText(item.title),
  text: item.text ? getLocationText(item.text) : undefined
}));

const iconSvgs: Record<string, string> = {
  percent: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>`,
  zero: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>`,
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  home: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  building: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>`,
  wrench: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  settings: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
  map: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  clock: `<svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
};

const defaultIconKey = variant === "services" ? "wrench" : "check";
function getIcon(key?: string): string {
  return iconSvgs[key || ""] || iconSvgs[defaultIconKey];
}
---

<section class:list={[
  "fps-section relative overflow-hidden py-20 lg:py-28",
  variant === "features" ? "bg-[var(--brand-tertiary)]" : "bg-[#F8F9FA]"
]}>
  
  {/* Cinematic Background Elements (Matching other pages) */}
  {variant === "features" ? (
    <div class="absolute inset-0 z-0 pointer-events-none">
       <div class="absolute inset-0" style="background: radial-gradient(circle at 10% 20%, color-mix(in srgb, var(--brand-tertiary), white 30%) 0%, transparent 40%), radial-gradient(circle at 90% 80%, color-mix(in srgb, var(--brand-tertiary), black 10%) 0%, transparent 40%), var(--brand-tertiary);"></div>
       <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(var(--brand-primary) 1px, transparent 1px); background-size: 32px 32px;"></div>
    </div>
  ) : (
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[var(--brand-primary)]/5 rounded-none blur-[120px] -translate-y-1/2 translate-x-1/3"></div>
  )}

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    
    <!-- Header Section -->
    <div class:list={[
      "max-w-4xl mb-12 lg:mb-20 reveal-on-scroll",
      variant === "features" ? "text-center mx-auto" : ""
    ]}>
      {badge && (
        <div class:list={[
          "inline-flex items-center gap-3 px-4 py-2 rounded-none border mb-6 transition-all duration-700",
          variant === "features" 
            ? "bg-[var(--brand-primary)]/5 border-[var(--brand-primary)]/10 text-[var(--brand-primary)] backdrop-blur-md" 
            : "bg-[var(--brand-primary)]/5 border-[var(--brand-primary)]/10 text-[var(--brand-primary)]"
        ]}>
          <span class="w-2 h-2 rounded-none bg-[var(--brand-highlight)] animate-pulse"></span>
          <span class="text-[0.65rem] font-black uppercase tracking-[0.3em]">{badge}</span>
        </div>
      )}
      
      <h2 class:list={[
        "text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-[1] mb-8",
        "text-[var(--brand-primary)]"
      ]}>
        {title}
      </h2>

      {subtitle && (
        <div class:list={[
          "relative inline-block",
          variant === "features" ? "max-w-3xl" : ""
        ]}>
           {variant !== "features" && <div class="absolute -left-8 top-0 bottom-0 w-1 bg-[var(--brand-highlight)] rounded-none hidden lg:block"></div>}
           <p class:list={[
             "text-lg lg:text-xl leading-relaxed font-semibold",
             variant === "features" ? "text-[var(--brand-primary)]/80" : "text-[var(--brand-secondary)]"
           ]} set:html={subtitle} />
        </div>
      )}
    </div>

    <!-- Features Grid Layout (Professional & Clean) -->
    {variant === "features" ? (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10 items-stretch" data-animate-stagger>
        {items.map((item, i) => (
          <div class="group relative transition-all duration-700 h-full">
            <div class="h-full bg-white/40 backdrop-blur-xl border border-white/60 rounded-none p-10 flex flex-col hover:bg-white/60 hover:-translate-y-2 transition-all duration-500 shadow-2xl shadow-[var(--brand-primary)]/5">
              {/* Subtle Step Indicator */}
              <div class="flex items-center gap-4 mb-10">
                <div class="w-16 h-16 bg-[var(--brand-primary)] text-white rounded-none flex items-center justify-center group-hover:scale-110 transition-transform duration-500 shadow-lg shadow-[var(--brand-primary)]/20">
                  <div class="w-8 h-8" set:html={getIcon(item.icon)} />
                </div>
                <div class="h-px flex-1 bg-[var(--brand-primary)]/10"></div>
                <span class="text-sm font-black text-[var(--brand-primary)]/20">{String(i + 1).padStart(2, '0')}</span>
              </div>

              <div class="relative z-10">
                <h3 class="text-2xl font-black uppercase tracking-tight leading-tight mb-6 text-[var(--brand-primary)] transition-colors duration-500">
                  {item.title}
                </h3>

                {item.text && (
                  <p class="text-[1.05rem] font-medium leading-relaxed text-[var(--brand-primary)]/70 transition-colors" set:html={item.text} />
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      /* Plans/Services Grid */
      <div class:list={[
        "grid gap-6 lg:gap-8",
        variant === "plans" ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" : "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4"
      ]} data-animate-stagger>
        {items.map((item, i) => {
          const isLink = !!item.href;
          const Tag = isLink ? "a" : "div";
          
          return (
            <Tag 
              href={isLink ? item.href : undefined}
              class="fps-card group relative flex flex-col transition-all duration-700 overflow-hidden bg-white border border-gray-100 rounded-none shadow-sm hover:shadow-2xl hover:shadow-[var(--brand-primary)]/10 hover:-translate-y-3"
            >
              {/* Image treatment for Services Variant */}
              {variant === "services" && item.image && (
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img 
                    src={item.image} 
                    alt={item.title} 
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-[var(--brand-primary)]/60 via-transparent to-transparent opacity-60 group-hover:opacity-20 transition-opacity duration-700"></div>
                  
                  {/* Floating Glass Icon */}
                  <div class="absolute top-6 right-6 z-20">
                    <div class="w-12 h-12 bg-white/30 backdrop-blur-xl rounded-none flex items-center justify-center text-white border border-white/20 shadow-2xl transition-all duration-500 group-hover:bg-[var(--brand-highlight)] group-hover:text-[var(--brand-primary)] group-hover:scale-110 group-hover:rotate-6">
                      <div class="w-6 h-6" set:html={getIcon(item.icon)} />
                    </div>
                  </div>
                </div>
              )}

              {/* Main Content Area */}
              <div class:list={[
                "flex-1 flex flex-col",
                variant === "services" && item.image ? "p-8 pt-6" : "p-10"
              ]}>
                
                {/* Icon for non-image variants */}
                {(!item.image || variant !== "services") && (
                  <div class="w-14 h-14 rounded-none flex items-center justify-center mb-8 transition-all duration-700 border bg-[var(--brand-primary)]/5 border-[var(--brand-primary)]/10 text-[var(--brand-primary)] group-hover:bg-[var(--brand-highlight)] group-hover:border-[var(--brand-highlight)] group-hover:scale-110 shadow-sm">
                    <div class="w-7 h-7" set:html={getIcon(item.icon)} />
                  </div>
                )}

                <h3 class="text-2xl font-black uppercase tracking-tight leading-[1.1] mb-4 text-[var(--brand-primary)] group-hover:text-[var(--brand-highlight)] transition-colors duration-500">
                  {item.title}
                </h3>

                {item.text && (
                  <p class="text-[0.95rem] font-medium leading-relaxed text-[var(--brand-secondary)] opacity-60 group-hover:opacity-100 transition-opacity" set:html={item.text} />
                )}

                {isLink && (
                  <div class="mt-auto pt-10 flex items-center justify-between group/btn">
                    <div class="w-10 h-10 rounded-none bg-[var(--brand-highlight)] text-[var(--brand-primary)] flex items-center justify-center transition-all duration-500 group-hover:bg-[var(--brand-primary)] group-hover:text-white group-hover:scale-110 shadow-lg shadow-[var(--brand-highlight)]/20">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-500 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>
                )}
              </div>

              {/* Subtle Hover Gradient Accent */}
              <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-10 transition-opacity duration-700 bg-gradient-to-br from-white to-transparent"></div>
            </Tag>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: all 1s cubic-bezier(0.25, 1, 0.3, 1);
  }
  
  .reveal-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initFinancingReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  initFinancingReveal();
  document.addEventListener('astro:page-load', initFinancingReveal);
</script>

