---
interface Service {
  title: string;
  description: string;
  href?: string;
}

interface ServiceCategory {
  title: string;
  services: Service[];
}

interface Props {
  title: string;
  description: string;
  categories: ServiceCategory[];
  badge?: string;
}

const { title, description, categories, badge = "Our Services" } = Astro.props;
---

<section class="ss-section relative overflow-hidden bg-white py-20 md:py-32" data-animate="fade-up">
  <!-- Subtle Background Accents -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[var(--brand-primary)]/5 rounded-none blur-[100px] pointer-events-none z-0"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[var(--brand-highlight)]/5 rounded-none blur-[100px] pointer-events-none z-0"></div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">

    <!-- Premium Header -->
    <div class="mb-16 lg:mb-24" data-animate="fade-up">
      <div class="mb-8">
        <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-[var(--brand-primary)]/5 rounded-none border border-[var(--brand-primary)]/10 shadow-sm">
          <span class="w-2.5 h-2.5 rounded-none bg-[var(--brand-highlight)] shadow-[0_0_8px_rgba(var(--brand-highlight-rgb),0.5)] animate-pulse"></span>
          <span class="text-xs font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">{badge}</span>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-[1.05]">
          {title}
        </h2>
        <div class="relative">
          <div class="absolute -left-8 top-0 bottom-0 w-1 bg-[var(--brand-highlight)] rounded-none hidden lg:block"></div>
          <p class="text-[1.05rem] text-[var(--brand-secondary)] lg:text-lg leading-relaxed font-medium" set:html={description} />
        </div>
      </div>
    </div>

    <!-- Categories -->
    <div class="ss-categories space-y-24 md:space-y-32" data-animate-stagger>
      {categories.map((category) => (
        <div class="ss-category">
          <div class="flex items-center gap-5 mb-12">
            <div class="w-12 h-1 bg-[var(--brand-highlight)] rounded-none shadow-[0_0_10px_rgba(var(--brand-highlight-rgb),0.3)]"></div>
            <h3 class="text-xs font-black uppercase tracking-[0.25em] text-[var(--brand-primary)] opacity-60">{category.title}</h3>
            <div class="flex-grow h-px bg-gray-100"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {category.services.map((service) => {
              const isLink = !!service.href;
              const Tag = isLink ? 'a' : 'div';
              return (
                <Tag
                  {...(isLink ? { href: service.href } : {})}
                  class="group relative bg-white rounded-none p-8 md:p-10 border border-gray-100 shadow-[0_15px_40px_-10px_rgba(0,0,0,0.05)] transition-all duration-500 hover:shadow-[0_25px_60px_-15px_rgba(0,0,0,0.12)] hover:-translate-y-2 hover:border-[var(--brand-highlight)]/50 no-underline text-inherit flex flex-col h-full"
                >
                  <!-- Animated Accent Line -->
                  <div class="absolute top-0 left-0 right-0 h-[4px] bg-[var(--brand-highlight)] scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100 rounded-none"></div>
                  
                  <h4 class="text-xl md:text-2xl font-black uppercase text-[var(--brand-primary)] tracking-tight mb-4 transition-colors duration-300 group-hover:text-[var(--brand-highlight)] leading-tight">{service.title}</h4>
                  <div class="text-sm md:text-base text-gray-500 font-medium leading-relaxed mb-10 flex-grow" set:html={service.description} />
                  
                  {isLink && (
                    <div class="mt-auto self-start">
                      <div class="w-12 h-12 bg-[var(--brand-primary)]/5 rounded-none flex items-center justify-center text-[var(--brand-primary)] transition-all duration-500 group-hover:bg-[var(--brand-primary)] group-hover:text-white group-hover:translate-x-1 group-hover:shadow-lg group-hover:shadow-[var(--brand-primary)]/20">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                      </div>
                    </div>
                  )}
                </Tag>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Ensure consistent spacing for injected HTML content */
  .ss-category :global(p) {
    margin-bottom: 1rem;
  }
  .ss-category :global(p:last-child) {
    margin-bottom: 0;
  }
</style>

