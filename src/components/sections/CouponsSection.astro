---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";
import { getLocationText } from "@/config/site"

interface Coupon {
  icon?: string;
  label: string;
  discount: string;
  description: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

interface Props {
  title?: string;
  coupons: Coupon[];
  backgroundImage?: string;
}

const {
  title: rawTitle = "Specials and Offers",
  coupons,
  backgroundImage,
} = Astro.props;

const title = getLocationText(rawTitle);
const centerIndex = Math.floor(coupons.length / 2);

const defaultBackgrounds = [
  'https://johnh967.sg-host.com/wp-content/uploads/2024/12/AC-Repair-Services.webp',
  'https://johnh967.sg-host.com/wp-content/uploads/sb-instagram-feed-images/466556611_1575760946412367_152571973762791733_nfull.webp',
  'https://johnh967.sg-host.com/wp-content/uploads/slider/cache/3208844a78ae424ec0bfef8623738be2/HVAC-Repair-Banner.webp'
];
---

<section class="cpn-section relative overflow-hidden py-20 md:py-32 bg-[var(--brand-primary)]">
  <!-- Dynamic Background Glow -->
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--brand-primary)]/80 via-transparent to-[var(--brand-primary)] mix-blend-multiply z-[1] pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[var(--brand-highlight)]/10 rounded-full blur-[120px] pointer-events-none z-[1]"></div>

  <div class="relative z-[2] container mx-auto px-4 md:px-8 lg:px-12">
    <!-- Section header -->
    <div class="flex flex-col items-center gap-5 mb-20 text-center" data-animate="fade-scale">
      <div class="inline-flex items-center gap-3 px-5 py-2 bg-[var(--brand-highlight)]/10 backdrop-blur-xl rounded-full border border-[var(--brand-highlight)]/30 shadow-[0_0_20px_rgba(var(--brand-highlight-rgb),0.2)]">
        <span class="w-2.5 h-2.5 rounded-full bg-[var(--brand-highlight)] shadow-[0_0_10px_var(--brand-highlight)] animate-pulse"></span>
        <span class="text-xs tracking-[0.25em] font-black text-white uppercase drop-shadow-md">Limited Time</span>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-white/70 uppercase tracking-tight leading-[1.1] drop-shadow-2xl">
        {title}
      </h2>
    </div>

    <!-- Coupons grid -->
    <div class="cpn-grid max-w-[85rem] mx-auto" data-animate-stagger>
      {coupons.map((coupon, i) => {
        const cardBg = coupon.backgroundImage || (i === centerIndex && backgroundImage) || defaultBackgrounds[i % defaultBackgrounds.length];
        return (
          <div class:list={["cpn-coupon group", { "cpn-coupon--featured": i === centerIndex }]}>
            
            <!-- Top: Image Strip -->
            <div class="relative h-56 rounded-t-[1.5rem] overflow-hidden">
              <div class="absolute inset-0 transition-transform duration-1000 ease-out group-hover:scale-110">
                <Image
                  src={cardBg}
                  alt={coupon.label}
                  class="w-full h-full object-cover"
                  width={600}
                  height={360}
                  format="webp"
                  quality={70}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <!-- Dark overlay for text legibility -->
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1a] via-[#0a0f1a]/50 to-transparent z-[1]"></div>
              
              <div class="relative z-[2] flex flex-col justify-end h-full p-8 pb-4">
                <span class="inline-block w-max text-sm font-black uppercase tracking-[0.2em] text-[var(--brand-highlight)] drop-shadow-md">
                  {coupon.label}
                </span>
              </div>
              
              <!-- Corner ribbon for featured -->
              {i === centerIndex && (
                <div class="absolute top-6 -right-10 z-[5] bg-gradient-to-r from-[var(--brand-highlight)] to-white text-[var(--brand-primary)] text-xs font-black uppercase tracking-widest py-2 px-12 rotate-45 shadow-[0_5px_20px_rgba(0,0,0,0.5)]">
                  Best Deal
                </div>
              )}
            </div>

            <!-- Modern Ticket Tear Line -->
            <div class="relative h-10 bg-[#0a0f1a] flex items-center z-10 -my-1">
              <div class="flex-1 border-t-2 border-dashed border-white/20 mx-8"></div>
            </div>

            <!-- Bottom: Coupon Details -->
            <div class="flex flex-col flex-1 p-8 pt-4 relative bg-[#0a0f1a] rounded-b-[1.5rem] z-[2]">
              <div class="mb-4">
                <span class="font-black text-5xl lg:text-7xl leading-none text-transparent bg-clip-text bg-gradient-to-br from-white via-white to-[var(--brand-highlight)] tracking-tighter drop-shadow-[0_0_30px_rgba(255,255,255,0.2)] block">
                  {coupon.discount}
                </span>
              </div>
              <p class="text-gray-300/90 text-base font-medium leading-relaxed mb-10 flex-1">
                {coupon.description}
              </p>
              
              <div class="mt-auto">
                <Button 
                  href={coupon.buttonHref || "/contact"} 
                  variant="white" 
                  rounded="2xl" 
                  size="lg"
                  className="w-full"
                  showArrow={true}
                >
                  {coupon.buttonText || "GET OFFER"}
                </Button>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ─── Grid ─── */
  .cpn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    align-items: stretch;
  }

  /* Lift the middle card on desktop */
  @media (min-width: 1024px) {
    .cpn-grid > :nth-child(2) {
      transform: scale(1.05) translateY(-1rem);
    }
  }

  /* ─── Coupon Card (Eye-catching) ─── */
  .cpn-coupon {
    display: flex;
    flex-direction: column;
    position: relative;
    border-radius: 1.5rem;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
    background: #0a0f1a;
  }

  /* Gradient Border Magic */
  .cpn-coupon::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: calc(1.5rem + 2px);
    background: linear-gradient(135deg, color-mix(in srgb, var(--brand-highlight) 80%, transparent), rgba(255,255,255,0.1) 40%, rgba(255,255,255,0.05) 60%, color-mix(in srgb, var(--brand-highlight) 30%, transparent));
    z-index: -1;
    opacity: 0.6;
    transition: opacity 0.4s ease;
  }

  .cpn-coupon:hover {
    transform: translateY(-12px);
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.7);
  }

  .cpn-coupon:hover::before {
    opacity: 1;
    background: linear-gradient(135deg, var(--brand-highlight), rgba(255,255,255,0.3) 40%, rgba(255,255,255,0.1) 60%, var(--brand-highlight));
  }

  /* Featured card intense glow */
  .cpn-coupon--featured {
    z-index: 10;
  }
  .cpn-coupon--featured::before {
    opacity: 1;
    background: linear-gradient(135deg, var(--brand-highlight), rgba(255,255,255,0.5), var(--brand-highlight));
    animation: borderRotate 4s linear infinite;
  }
  .cpn-coupon--featured::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: calc(1.5rem + 2px);
    background: var(--brand-highlight);
    z-index: -2;
    filter: blur(20px);
    opacity: 0.3;
  }
  
  @keyframes borderRotate {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ─── Responsive ─── */
  @media (max-width: 1200px) {
    .cpn-grid { gap: 2rem; }
  }

  @media (max-width: 1024px) {
    .cpn-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .cpn-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .cpn-grid > :nth-child(2) {
      transform: none;
    }
    .cpn-coupon:hover {
      transform: translateY(-4px);
    }
  }
</style>
