---
import { siteConfig, getLocationText } from "@/config/site"

interface Props {
  title?: string;
  description?: string;
  image?: string;
  phone?: string;
  email?: string;
  address?: string;
  serviceOptions?: string[];
  planOptions?: string[];
}

const {
  title: rawTitle = `Get in Touch`,
  description: rawDescription = "Fill out the form, and a member of our team will get back to you promptly.",
  image = "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=800&q=80",
  phone = siteConfig.contact.phoneFormatted,
  email = siteConfig.contact.email,
  address = `${siteConfig.location.city}, ${siteConfig.location.state}`,
  serviceOptions = ["Air Conditioning", "Heating", "Indoor Air Quality", "Emergency Service", "Commercial HVAC", "Maintenance", "Other"],
  planOptions = ["Yes", "No", "Not Sure"]
} = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
---

<section class="relative py-20 lg:py-32 bg-gray-50/50 overflow-hidden">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center">
      
      <!-- Left Side: Professional Information -->
      <div class="lg:col-span-5" data-animate="fade-right">
        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2.5 px-4 py-1.5 bg-[var(--brand-primary)]/5 border border-[var(--brand-primary)]/10 rounded-full mb-8">
             <div class="w-1.5 h-1.5 rounded-full bg-[var(--brand-highlight)] animate-pulse"></div>
             <span class="text-[0.65rem] font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">Contact</span>
          </div>
          
          <h2 class="text-5xl lg:text-7xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-[0.9] mb-8">
            {title}
          </h2>

          <p class="text-gray-500 text-lg font-medium leading-relaxed max-w-xl mb-12" set:html={description} />

          <div class="space-y-6 lg:space-y-8">
            {[
              { label: "Phone", value: phone, href: `tel:${phone.replace(/\D/g, '')}`, icon: "phone" },
              { label: "Email Address", value: email, href: `mailto:${email}`, icon: "mail" },
              { label: "Address", value: address, href: "/service-areas", icon: "map-pin" }
            ].map(info => (
              <div class="flex items-center gap-6 group">
                <div class="w-14 h-14 bg-[var(--brand-primary)]/5 rounded-2xl flex items-center justify-center text-[var(--brand-primary)] group-hover:bg-[var(--brand-primary)] group-hover:text-white transition-all duration-500 shadow-sm border border-[var(--brand-primary)]/5">
                  {info.icon === "phone" && <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>}
                  {info.icon === "mail" && <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>}
                  {info.icon === "map-pin" && <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>}
                </div>
                <div>
                  <div class="text-[0.6rem] font-black text-gray-400 uppercase tracking-[0.3em] mb-1">{info.label}</div>
                  <a href={info.href} class="text-xl lg:text-2xl font-black text-[var(--brand-primary)] hover:text-[var(--brand-highlight)] transition-all duration-300 leading-tight">
                    {info.value}
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right Side: Professional Form Panel -->
      <div class="lg:col-span-7 flex flex-col justify-center" data-animate="fade-left">

        <!-- Clean Form Container -->
        <div class="bg-white rounded-[2.5rem] p-9 lg:p-13 shadow-[0_40px_100px_-30px_rgba(0,0,0,0.06)] border border-gray-100 relative overflow-hidden flex flex-col justify-center">
          <!-- Subtle corner accent -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-gray-50 rounded-bl-full -mr-16 -mt-16 pointer-events-none"></div>
          
          <h3 class="text-[0.6rem] font-black text-[var(--brand-primary)] uppercase tracking-[0.3em] mb-8 flex items-center gap-2.5">
             <span class="w-1.5 h-1.5 rounded-full bg-[var(--brand-highlight)]"></span>
             Contact Form
          </h3>

          <form class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6">
            <!-- Full Name -->
            <div class="md:col-span-2 group/field">
              <label class="block text-[0.55rem] font-black text-[var(--brand-primary)] uppercase tracking-widest mb-1.5 opacity-60">Name*</label>
              <div class="relative">
                <input type="text" required placeholder="Name" class="w-full bg-gray-50/50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm text-[var(--brand-primary)] placeholder:text-gray-400 focus:bg-white focus:border-[var(--brand-highlight)] focus:ring-4 focus:ring-[var(--brand-highlight)]/10 outline-none transition-all font-bold" />
              </div>
            </div>

            <!-- Email Address -->
            <div class="group/field">
              <label class="block text-[0.55rem] font-black text-[var(--brand-primary)] uppercase tracking-widest mb-1.5 opacity-60">Email Address*</label>
              <input type="email" required placeholder="Email Address" class="w-full bg-gray-50/50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm text-[var(--brand-primary)] placeholder:text-gray-400 focus:bg-white focus:border-[var(--brand-highlight)] focus:ring-4 focus:ring-[var(--brand-highlight)]/10 outline-none transition-all font-bold" />
            </div>

            <!-- Phone -->
            <div class="group/field">
              <label class="block text-[0.55rem] font-black text-[var(--brand-primary)] uppercase tracking-widest mb-1.5 opacity-60">Phone</label>
              <input type="tel" placeholder="Phone" class="w-full bg-gray-50/50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm text-[var(--brand-primary)] placeholder:text-gray-400 focus:bg-white focus:border-[var(--brand-highlight)] focus:ring-4 focus:ring-[var(--brand-highlight)]/10 outline-none transition-all font-bold" />
            </div>

            <!-- Plan Select -->
            <div class="group/field">
              <label class="block text-[0.55rem] font-black text-[var(--brand-primary)] uppercase tracking-widest mb-1.5 opacity-60">Are You Interested In A Plan?</label>
              <div class="relative">
                <select class="w-full bg-gray-50/50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm text-[var(--brand-primary)] focus:bg-white focus:border-[var(--brand-highlight)] focus:ring-4 focus:ring-[var(--brand-highlight)]/10 outline-none transition-all font-bold appearance-none cursor-pointer">
                  <option value="">Select Option</option>
                  {planOptions.map(opt => <option value={opt}>{opt}</option>)}
                </select>
                <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>

            <!-- Service Select -->
            <div class="group/field">
              <label class="block text-[0.55rem] font-black text-[var(--brand-primary)] uppercase tracking-widest mb-1.5 opacity-60">Which Service Do You Need?</label>
              <div class="relative">
                <select class="w-full bg-gray-50/50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm text-[var(--brand-primary)] focus:bg-white focus:border-[var(--brand-highlight)] focus:ring-4 focus:ring-[var(--brand-highlight)]/10 outline-none transition-all font-bold appearance-none cursor-pointer">
                  <option value="">Select Service</option>
                  {serviceOptions.map(opt => <option value={opt}>{opt}</option>)}
                </select>
                <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>

            <!-- Message -->
            <div class="md:col-span-2 group/field">
              <label class="block text-[0.55rem] font-black text-[var(--brand-primary)] uppercase tracking-widest mb-1.5 opacity-60">Message*</label>
              <textarea rows="3" required placeholder="Message" class="w-full bg-gray-50/50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm text-[var(--brand-primary)] placeholder:text-gray-400 focus:bg-white focus:border-[var(--brand-highlight)] focus:ring-4 focus:ring-[var(--brand-highlight)]/10 outline-none transition-all font-bold resize-none"></textarea>
            </div>

            <!-- Verification -->
            <div class="md:col-span-2 group/field">
              <label class="block text-[0.55rem] font-black text-[var(--brand-primary)] uppercase tracking-widest mb-1.5 opacity-60">Verification*</label>
              <input type="text" required placeholder="Verification" class="w-full bg-gray-50/50 border border-gray-200 rounded-xl px-5 py-3.5 text-sm text-[var(--brand-primary)] placeholder:text-gray-400 focus:bg-white focus:border-[var(--brand-highlight)] focus:ring-4 focus:ring-[var(--brand-highlight)]/10 outline-none transition-all font-bold" />
            </div>

            <!-- Submit Button -->
            <div class="md:col-span-2 pt-4">
               <button type="submit" class="group w-full bg-[var(--brand-primary)] text-white font-black text-[0.65rem] uppercase tracking-[0.3em] py-4 rounded-xl shadow-lg hover:bg-[var(--brand-highlight)] hover:text-[var(--brand-primary)] transition-all duration-300 flex items-center justify-center gap-3">
                 <span>Submit</span>
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
               </button>
            </div>
          </form>

          <!-- Minimalist Trust Trust Footer -->
          <div class="mt-12 pt-8 border-t border-gray-50 flex flex-wrap justify-center gap-x-8 gap-y-4">
            {["Secure Transmission", "Verified Response", "Privacy Guaranteed"].map(text => (
              <div class="flex items-center gap-2.5">
                <div class="w-1 h-1 rounded-full bg-[var(--brand-highlight)]"></div>
                <span class="text-[0.6rem] font-black text-gray-400 uppercase tracking-widest">{text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
