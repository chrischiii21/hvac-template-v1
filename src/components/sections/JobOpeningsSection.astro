---
import { getLocationText } from "@/config/site"
import { Button } from "@/components/ui/button"
import { Card, CardContent } from "@/components/ui/card"

interface JobOpening {
  title: string;
  type?: string;
  responsibilities: string;
  buttonText?: string;
  buttonHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  jobs: JobOpening[];
  introTitle?: string;
  introDescription?: string;
}

const { badge, title, description, jobs, introTitle: rawIntroTitle, introDescription: rawIntroDescription } = Astro.props;

const introTitle = rawIntroTitle ? getLocationText(rawIntroTitle) : undefined;
const introDescription = rawIntroDescription ? getLocationText(rawIntroDescription) : undefined;
---

<section class="jo-section" id="openings">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-28">

    {/* Intro header */}
    {introTitle && (
      <div class="jo-intro" data-animate="fade-up">
        <div class="jo-eyebrow">
          <span class="jo-eyebrow-text">Careers</span>
        </div>
        <h2 class="jo-intro-title">{introTitle}</h2>
        <div class="jo-divider"></div>
        {introDescription && <p class="jo-intro-desc">{introDescription}</p>}
      </div>
    )}

    {/* Openings subheader */}
    <div class="jo-subheader" data-animate="fade-up">
      <div class="jo-subheader-inner">
        <div class="jo-subheader-line"></div>
        <h3 class="jo-subheader-title">{title}</h3>
      </div>
      {description && <p class="jo-subheader-desc" set:html={description} />}
    </div>

    {/* Job cards using React Card/Button */}
    <div class="jo-grid" data-animate-stagger>
      {jobs.map((job, i) => (
        <Card className="relative overflow-hidden group border-gray-100 hover:border-[var(--brand-highlight)] h-full">
          {/* Top accent line sweep */}
          <span class="absolute top-0 left-0 right-0 h-[4px] bg-[var(--brand-highlight)] scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100 z-10"></span>

          {/* Background number */}
          <div class="absolute -bottom-6 right-2 text-9xl font-black leading-none text-[var(--brand-primary)] opacity-[0.03] pointer-events-none select-none z-0">
            {String(i + 1).padStart(2, '0')}
          </div>

          <CardContent className="relative flex flex-col p-8 md:p-10 min-h-[340px] z-10 h-full">
            <h3 class="text-xl md:text-2xl font-black uppercase text-[var(--brand-primary)] tracking-tight mb-2">{job.title}</h3>
            <span class="text-xs font-bold uppercase tracking-[0.1em] text-[var(--brand-secondary)]">{job.type || "Full-time position"}</span>

            <div class="w-12 h-[3px] bg-[var(--brand-highlight)] my-6 shadow-[0_0_10px_rgba(var(--brand-highlight-rgb),0.5)]"></div>

            <p class="text-sm md:text-base leading-relaxed text-gray-600 mb-8 flex-grow">
              <span class="font-bold text-[var(--brand-primary)]">Responsibilities:</span> {job.responsibilities}
            </p>

            <Button asChild className="self-start mt-auto group/btn">
              <a href={job.buttonHref || "/contact"}>
                {job.buttonText || "APPLY NOW"}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2 transition-transform duration-300 group-hover/btn:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </Button>
          </CardContent>
        </Card>
      ))}
    </div>
  </div>
</section>

<style>
  .jo-section {
    background: var(--brand-tertiary);
  }

  /* ─── Intro Header ─── */
  .jo-intro {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }
  .jo-eyebrow {
    margin-bottom: 1.25rem;
  }
  .jo-eyebrow-text {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--brand-highlight);
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--brand-primary);
  }
  .jo-intro-title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--brand-primary);
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) {
    .jo-intro-title { font-size: 2.25rem; }
  }
  .jo-divider {
    width: 3rem;
    height: 3px;
    background: var(--brand-highlight);
    margin: 0 auto 1.25rem;
  }
  .jo-intro-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--brand-secondary);
  }

  /* ─── Subheader ─── */
  .jo-subheader {
    margin-bottom: 2.5rem;
    max-width: 64rem;
    margin-left: auto;
    margin-right: auto;
  }
  .jo-subheader-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .jo-subheader-line {
    width: 3px;
    height: 24px;
    background: var(--brand-highlight);
    flex-shrink: 0;
  }
  .jo-subheader-title {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-primary);
  }
  .jo-subheader-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--brand-secondary);
    padding-left: calc(3px + 0.75rem);
  }

  /* ─── Grid ─── */
  .jo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .jo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .jo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
