---
import Button from "../ui/Button.astro";
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site";

interface Props {
  badge?: string;
  title: string;
  description: string;
  features?: string[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  images?: string[];
  imageAlts?: string[];
}

const {
  badge,
  title: rawTitle,
  description: rawDescription,
  features: rawFeatures = [],
  buttonText,
  buttonHref,
  imagePosition = "left",
  images = [],
  imageAlts = [],
} = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const features = rawFeatures.map(getLocationText);

const mainImage = images[0] || "";
const isRight = imagePosition === "right";
---

<section class="cs-wrapper relative overflow-hidden bg-white py-16 lg:py-24">
  <!-- Decorative Abstract Background -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] opacity-[0.03] pointer-events-none z-0"
  >
    <svg
      viewBox="0 0 1000 1000"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full h-full"
    >
      <path
        d="M750,250 C850,350 850,550 750,650 C650,750 450,750 350,650 C250,550 250,350 350,250 C450,150 650,150 750,250"
        fill="var(--brand-primary)"></path>
    </svg>
  </div>

  <div
    class:list={[
      "container mx-auto px-6 md:px-12 lg:px-16 relative z-10",
      { "cs-container--flipped": isRight },
    ]}
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <!-- Modern Floating Image Side -->
      <div
        class:list={[
          "lg:col-span-6 relative",
          isRight ? "lg:order-2" : "lg:order-1",
        ]}
        data-animate={isRight ? "fade-left" : "fade-right"}
      >
        <div class="relative max-w-[540px] mx-auto lg:mx-0 group">
          <!-- Decorative Offset Border -->
          <div
            class="absolute inset-0 border-2 border-[var(--brand-highlight)] rounded-none translate-x-4 translate-y-4 lg:translate-x-6 lg:translate-y-6 z-0 transition-transform duration-500 group-hover:translate-x-2 group-hover:translate-y-2"
          >
          </div>

          <!-- Background Glow -->
          <div
            class="absolute -inset-10 bg-[var(--brand-primary)]/10 rounded-none blur-[60px] z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700"
          >
          </div>

          <!-- Main Image Container -->
          <div
            class="relative z-10 rounded-none overflow-hidden shadow-[0_25px_60px_-15px_rgba(0,0,0,0.2)] aspect-[4/5] sm:aspect-square lg:aspect-[4/5]"
          >
            {
              mainImage ? (
                <Image
                  src={mainImage}
                  alt={imageAlts[0] || title}
                  class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                  loading="lazy"
                  width={800}
                  height={1000}
                  format="avif"
                  quality={85}
                  decoding="async"
                  fetchpriority="low"
                />
              ) : (
                <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-400">
                  <span>Image</span>
                </div>
              )
            }

            <!-- Bottom Glassmorphic Card (Visual Only) -->
            <div
              class="absolute bottom-6 left-6 right-6 md:bottom-8 md:left-8 md:right-8 bg-white/90 backdrop-blur-md p-4 rounded-none border border-white/40 shadow-xl z-20 transition-all duration-500 group-hover:-translate-y-2"
            >
              <div class="flex items-center gap-4">
                <div
                  class="flex-shrink-0 w-10 h-10 bg-[var(--brand-primary)] rounded-none flex items-center justify-center text-[var(--brand-highlight)] shadow-lg shadow-[var(--brand-primary)]/20"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                    ></path>
                    <path d="m9 12 2 2 4-4"></path>
                  </svg>
                </div>
                <div
                  class="w-full h-2 bg-[var(--brand-primary)]/10 rounded-none"
                >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Text Side -->
      <div
        class:list={["lg:col-span-6", isRight ? "lg:order-1" : "lg:order-2"]}
        data-animate={isRight ? "fade-right" : "fade-left"}
        data-animate-delay="200"
      >
        <div class="max-w-xl mx-auto lg:mx-0">
          {
            badge && (
              <div class="mb-6 lg:mb-8">
                <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-[var(--brand-primary)]/5 rounded-none border border-[var(--brand-primary)]/10 shadow-sm">
                  <span class="w-2.5 h-2.5 rounded-none bg-[var(--brand-highlight)] shadow-[0_0_8px_rgba(var(--brand-highlight-rgb),0.5)] animate-pulse" />
                  <span class="text-xs font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">
                    {badge}
                  </span>
                </div>
              </div>
            )
          }

          <h2
            class="text-3xl md:text-4xl lg:text-5xl font-black text-[var(--brand-primary)] uppercase tracking-tight leading-[1.1] mb-6"
          >
            {title}
          </h2>

          <div class="mb-10">
            <p class="text-[1.05rem] text-[var(--brand-secondary)] lg:text-lg leading-relaxed font-medium" set:html={description} />
          </div>

          {
            features.length > 0 && (
              <div
                class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-12"
                data-animate-stagger
              >
                {features.map((feature) => (
                  <div class="group flex items-center gap-4 p-4 bg-white border border-gray-100 rounded-none shadow-sm transition-all duration-300 hover:border-gray-200 hover:shadow-md hover:-translate-y-1">
                    <span class="w-2 h-2 rounded-none bg-[var(--brand-highlight)] shadow-[0_0_8px_rgba(var(--brand-highlight-rgb),0.5)] flex-shrink-0 transition-transform duration-300 group-hover:scale-150" />
                    <span
                      class="text-[var(--brand-primary)] font-bold text-xs md:text-sm leading-tight"
                      set:html={feature}
                    />
                  </div>
                ))}
              </div>
            )
          }

          {
            buttonText && buttonHref && (
              <Button href={buttonHref} variant="primary" size="lg">
                {buttonText}
              </Button>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Ensure description styles inherit correctly */
  .text-gray-600 :global(p) {
    margin-bottom: 1.5rem;
  }
  .text-gray-600 :global(p:last-child) {
    margin-bottom: 0;
  }
  .text-gray-600 :global(strong) {
    color: var(--brand-primary);
    font-weight: 800;
  }
</style>

