---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title: rawTitle,
  description: rawDescription,
  buttonText = "APPLY TODAY",
  buttonHref = "/contact",
  image,
  imageAlt = "Join our team"
} = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
---

<section class="career-banner-section overflow-hidden">
  <!-- Dynamic Mesh & Image Background -->
  <div class="banner-canvas">
    <div class="banner-mesh"></div>
    <div class="banner-blobs">
      <div class="banner-blob banner-blob-1"></div>
      <div class="banner-blob banner-blob-2"></div>
    </div>
    
    <!-- Integrated Image -->
    {image && (
      <div class="banner-image-wrap">
        <img src={image} alt={imageAlt} class="banner-img" />
        <div class="banner-img-overlay"></div>
      </div>
    )}
  </div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-20 md:py-24 relative z-10">
    <div class="banner-grid" data-animate="fade-up">
      
      <!-- Content Area -->
      <div class="banner-content">
        <div class="banner-badge-wrap">
          <span class="banner-badge">
            <span class="banner-badge-pulse"></span>
            Join Us
          </span>
        </div>

        <h2 class="banner-title" set:html={title} />
        
        {description && (
          <p class="banner-description" set:html={description} />
        )}

        <div class="banner-actions">
          <a href={buttonHref} class="banner-btn">
            <span class="banner-btn-text">{buttonText}</span>
            <div class="banner-btn-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .career-banner-section {
    position: relative;
    background: var(--brand-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* ─── Canvas & Image Integration ─── */
  .banner-canvas { position: absolute; inset: 0; z-index: 1; overflow: hidden; }
  .banner-mesh {
    position: absolute; inset: 0;
    background: 
      radial-gradient(at 0% 0%, color-mix(in srgb, var(--brand-primary), white 8%) 0px, transparent 50%),
      var(--brand-primary);
  }
  .banner-blobs { position: absolute; inset: 0; filter: blur(100px); opacity: 0.15; }
  .banner-blob { position: absolute; border-radius: 50%; animation: bannerBlob 30s infinite alternate ease-in-out; }
  .banner-blob-1 { width: 40vw; height: 40vw; background: var(--brand-highlight); top: -10%; left: -10%; }
  .banner-blob-2 { width: 30vw; height: 30vw; background: white; bottom: -5%; right: 20%; animation-delay: -5s; }

  @keyframes bannerBlob {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(60px, 40px) scale(1.1); }
  }

  .banner-image-wrap {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    z-index: 2;
    display: none;
  }
  @media (min-width: 1024px) {
    .banner-image-wrap { display: block; }
  }

  .banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .banner-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, var(--brand-primary) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.3) 100%);
  }

  /* ─── Layout ─── */
  .banner-grid {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1200px;
  }
  @media (min-width: 1024px) {
    .banner-grid { grid-template-columns: repeat(12, 1fr); }
  }

  /* ─── Content ─── */
  .banner-content {
    text-align: center;
  }
  @media (min-width: 1024px) {
    .banner-content {
      grid-column: span 8;
      text-align: left;
    }
  }

  .banner-badge-wrap { margin-bottom: 1.5rem; }
  .banner-badge {
    display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.4rem 1.25rem;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border-radius: 99px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.2em; color: var(--brand-highlight);
  }
  .banner-badge-pulse { 
    width: 6px; height: 6px; background: var(--brand-highlight); border-radius: 50%; 
    box-shadow: 0 0 10px var(--brand-highlight);
    animation: b-pulse 2s infinite;
  }

  @keyframes b-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
  }

  .banner-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900;
    line-height: 0.95;
    color: white;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
  }

  .banner-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
    max-width: 36rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 1023px) {
    .banner-description { margin-left: auto; margin-right: auto; }
  }

  /* ─── Actions ─── */
  .banner-btn {
    display: inline-flex;
    align-items: center;
    background: white;
    color: var(--brand-primary);
    padding: 0.5rem;
    padding-left: 2rem;
    border-radius: 99px;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .banner-btn-icon {
    width: 48px;
    height: 48px;
    background: var(--brand-highlight);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: 1.5rem;
    color: var(--brand-primary);
    transition: all 0.4s ease;
  }

  .banner-btn:hover {
    background: var(--brand-highlight);
    transform: translateY(-3px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  .banner-btn:hover .banner-btn-icon {
    background: var(--brand-primary);
    color: white;
    transform: rotate(-45deg);
  }

  @media (max-width: 1023px) {
    .banner-btn { width: 100%; max-width: 320px; justify-content: space-between; }
  }
</style>

