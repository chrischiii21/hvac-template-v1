---
import { Image } from "astro:assets";

interface Badge {
  name: string;
  image: string;
  alt?: string;
}

interface Props {
  badges?: Badge[];
  heading?: string;
}

const {
  badges = [
    { name: "Home Advisor", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Home-Advisor-Logo.webp" },
    { name: "BBB", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/BBB-Logo.webp" },
    { name: "Google Reviews", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Google-Reviews-Logo.webp" },
    { name: "Angie's List Award", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Angies-List-Award.webp" },
    { name: "Licensed", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Licensed.webp" }
  ],
  heading = "Achievement Starts with Action."
} = Astro.props;

// Split the heading nicely for the typography
const words = heading.split(' ');
const mid = Math.ceil(words.length / 2);
const firstHalf = words.slice(0, mid).join(' ');
const secondHalf = words.slice(mid).join(' ');
---

<section class="trust-strip-section relative w-full bg-[var(--brand-primary)] py-10 md:py-14 border-b border-white/10">
  <div class="container mx-auto px-4 md:px-6 max-w-7xl flex flex-col items-center relative z-10">
    
    <!-- Centered Text Block -->
    <div class="flex flex-col items-center gap-4 mb-10 md:mb-14 text-center">
      <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-white/10 backdrop-blur-xl rounded-none border border-white/20 shadow-lg">
        <span class="w-2 h-2 rounded-none bg-[var(--brand-highlight)] shadow-[0_0_8px_var(--brand-highlight)] animate-pulse"></span>
        <span class="text-[10px] md:text-xs tracking-[0.2em] font-bold text-white uppercase drop-shadow-md">Trusted By Thousands</span>
      </div>
      <h2 class="text-2xl md:text-3xl font-black text-white uppercase tracking-tight leading-[1.15] drop-shadow-lg">
        <span>{firstHalf}</span> <span class="text-[var(--brand-highlight)]">{secondHalf}</span>
      </h2>
    </div>

    <!-- Carousel Container with Fade Mask -->
    <div class="w-full overflow-hidden mask-gradient relative flex max-w-6xl mx-auto pause-on-hover">
      
      <div class="flex animate-marquee shrink-0 items-center justify-around min-w-full gap-12 md:gap-24 pr-12 md:gap-24">
        {badges.map((badge) => (
           <div class="flex items-center justify-center flex-shrink-0">
              <Image
                src={badge.image}
                alt={badge.alt || badge.name}
                class="h-10 md:h-16 w-auto object-contain transition-all duration-300 filter grayscale opacity-80 hover:grayscale-0 hover:opacity-100 hover:scale-105"
                width={200}
                height={80}
                format="avif"
                quality={100}
                loading="lazy"
                decoding="async"
              />
           </div>
        ))}
      </div>

      <div class="flex animate-marquee shrink-0 items-center justify-around min-w-full gap-12 md:gap-24 pr-12 md:gap-24" aria-hidden="true">
        {badges.map((badge) => (
           <div class="flex items-center justify-center flex-shrink-0">
              <Image
                src={badge.image}
                alt={badge.alt || badge.name}
                class="h-10 md:h-16 w-auto object-contain transition-all duration-300 filter grayscale opacity-80 hover:grayscale-0 hover:opacity-100 hover:scale-105"
                width={200}
                height={80}
                format="avif"
                quality={100}
                loading="lazy"
                decoding="async"
              />
           </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }

  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
  
  .pause-on-hover:hover .animate-marquee {
    animation-play-state: paused;
  }
  
  .mask-gradient {
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }
</style>



