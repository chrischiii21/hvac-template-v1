---
import Button from "../ui/Button.astro";
import { Image } from "astro:assets";
import { siteConfig, getLocationText } from "@/config/site"

interface PromoTile {
  type: "maintenance" | "financing" | "emergency";
  tag?: string;
  title?: string;
  priceLabel?: string[];
  headline?: string[];
  subtext?: string;
  discount?: string;
  subheadline?: string[];
  phone?: string;
  buttonText: string;
  buttonHref?: string;
  bgImage?: string;
}

interface Props {
  tiles: PromoTile[];
}

const { tiles: rawTiles } = Astro.props;
const tiles = rawTiles.map(tile => ({
  ...tile,
  phone: tile.phone || siteConfig.contact.phoneFormatted,
  title: tile.title ? getLocationText(tile.title) : tile.title,
}));
---

<section class="pt-section relative overflow-hidden bg-[var(--brand-primary)] py-20 md:py-28">
  <!-- Cinematic Matrix Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 opacity-[0.02] bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:24px_24px]"></div>
    <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-transparent via-[var(--brand-highlight)]/5 to-transparent"></div>
    
    <!-- Sophisticated HUD Accents -->
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  </div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch" data-animate-stagger>

      {tiles.map((tile, index) => (
        <div class="pt-bento-card group relative flex flex-col h-full" data-animate="fade-up">
          
          <!-- Iridescent Glow (The "Set Apart" FX) -->
          <div class="absolute -inset-[2px] bg-gradient-to-br from-[var(--brand-highlight)]/40 via-transparent to-blue-500/20 rounded-none opacity-0 group-hover:opacity-100 blur-[2px] transition-all duration-700 z-0"></div>
          
          <!-- Glass Panel Foundation -->
          <div class="absolute inset-0 bg-[#0F0F0F]/90 backdrop-blur-xl border border-white/10 rounded-none transition-all duration-500 group-hover:bg-[#121212] group-hover:border-[var(--brand-highlight)]/50 z-[1] shadow-2xl"></div>
          
          {/* Parallax Depth Layer */}
          {tile.bgImage && (
            <div class="absolute inset-0 rounded-none overflow-hidden z-[1] opacity-[0.03] group-hover:opacity-[0.08] transition-opacity duration-1000">
              <Image
                src={tile.bgImage}
                alt=""
                class="w-full h-full object-cover grayscale transition-transform duration-[20s] group-hover:scale-125"
                widths={[300, 600]}
                sizes="(max-width: 768px) 100vw, 33vw"
                inferSize={true}
              />
            </div>
          )}

          <!-- Card Content (Creative HUD Layout) -->
          <div class="relative z-10 p-8 lg:p-10 flex flex-col h-full">
            
            <!-- Top HUD Row -->
            <div class="flex items-start justify-between mb-10">
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-none bg-[var(--brand-highlight)] shadow-[0_0_12px_rgba(var(--brand-highlight-rgb),1)]"></span>
                  <span class="text-[0.6rem] font-black text-white/30 uppercase tracking-[0.3em]">
                    {tile.tag || (tile.type === "maintenance" && "Plan") || (tile.type === "financing" && "Financing") || (tile.type === "emergency" && "Special")}
                  </span>
                </div>
                <span class="text-[0.5rem] font-black text-[var(--brand-highlight)] uppercase tracking-widest pl-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500">Live Status: Verified</span>
              </div>
              
              <div class="w-10 h-10 flex items-center justify-center bg-white/[0.03] border border-white/10 rounded-none text-[var(--brand-highlight)] group-hover:bg-[var(--brand-highlight)] group-hover:text-[var(--brand-primary)] group-hover:rotate-[360deg] transition-all duration-1000 shadow-xl">
                {tile.type === "maintenance" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                )}
                {tile.type === "financing" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                )}
                {tile.type === "emergency" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                )}
              </div>
            </div>

            <!-- Content Core (Unique Arrangement) -->
            <div class="flex-1">
              {tile.type === "maintenance" && (
                <div class="flex flex-col gap-8">
                  {tile.title && (
                    <h3 class="text-3xl lg:text-4xl font-black text-white uppercase tracking-tighter leading-[0.9] border-l-4 border-[var(--brand-highlight)] pl-6">{tile.title}</h3>
                  )}
                  {tile.priceLabel && (
                    <div class="relative p-6 bg-white/[0.02] border border-white/[0.05] rounded-none group-hover:bg-[var(--brand-highlight)]/[0.03] transition-all duration-500">
                      <span class="block text-[0.6rem] font-black text-white/20 uppercase tracking-[0.25em] mb-2">{tile.priceLabel[0]}</span>
                      <div class="flex items-baseline gap-2">
                        <span class="text-6xl lg:text-7xl font-black text-white tracking-tighter drop-shadow-2xl">{tile.priceLabel[1]}</span>
                        <span class="text-[0.7rem] font-black text-[var(--brand-highlight)] uppercase tracking-widest">{tile.priceLabel[2]}</span>
                      </div>
                    </div>
                  )}
                  <div class="flex items-center gap-3">
                    <div class="h-px flex-1 bg-white/5"></div>
                    <p class="text-[0.6rem] font-black text-white/20 uppercase tracking-[0.2em] whitespace-nowrap">Priority scheduling included</p>
                  </div>
                </div>
              )}

              {tile.type === "financing" && (
                <div class="flex flex-col gap-8">
                  {tile.headline && (
                    <div class="flex flex-col gap-2">
                      {tile.headline.map((line) => (
                        <p class="text-4xl lg:text-5xl font-black text-white uppercase tracking-tighter leading-[0.8] drop-shadow-2xl">{line}</p>
                      ))}
                    </div>
                  )}
                  {tile.subtext && (
                    <p class="inline-block px-3 py-1 bg-[var(--brand-highlight)]/10 text-[var(--brand-highlight)] text-[0.6rem] font-black uppercase tracking-widest rounded-none self-start">{tile.subtext}</p>
                  )}
                  <div class="grid grid-cols-1 gap-3 p-6 bg-white/[0.02] border border-white/[0.05] rounded-none group-hover:border-[var(--brand-highlight)]/20 transition-all duration-500">
                    <div class="flex items-center gap-3 text-[0.65rem] font-bold text-white/40 uppercase tracking-widest">
                      <div class="w-1.5 h-1.5 bg-[var(--brand-highlight)] rounded-none rotate-45"></div>
                      <span>Quick approval process</span>
                    </div>
                    <div class="flex items-center gap-3 text-[0.65rem] font-bold text-white/40 uppercase tracking-widest">
                      <div class="w-1.5 h-1.5 bg-[var(--brand-highlight)] rounded-none rotate-45"></div>
                      <span>Flexible payment options</span>
                    </div>
                  </div>
                </div>
              )}

              {tile.type === "emergency" && (
                <div class="flex flex-col gap-8">
                  <div class="relative">
                    {tile.discount && (
                      <p class="text-7xl lg:text-[6.5rem] font-black text-[var(--brand-highlight)] tracking-tighter leading-none mb-4">{tile.discount}</p>
                    )}
                    {tile.subheadline && (
                      <div class="flex flex-col gap-1 border-l-2 border-white/10 pl-6">
                        {tile.subheadline.map((line) => (
                          <p class="text-xl lg:text-2xl font-black text-white/90 uppercase tracking-tight leading-tight">{line}</p>
                        ))}
                      </div>
                    )}
                  </div>
                  <div class="flex flex-col gap-3 p-6 bg-white/[0.03] border border-white/10 rounded-none">
                    <div class="flex items-center justify-between text-[0.65rem] font-bold text-white/50 uppercase tracking-widest border-b border-white/5 pb-2">
                      <span>System inspection</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-[var(--brand-highlight)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    <div class="flex items-center justify-between text-[0.65rem] font-bold text-white/50 uppercase tracking-widest border-b border-white/5 pb-2">
                      <span>Filter replacement</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-[var(--brand-highlight)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    <div class="flex items-center justify-between text-[0.65rem] font-bold text-white/50 uppercase tracking-widest">
                      <span>Performance report</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-[var(--brand-highlight)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                  </div>
                  <p class="text-[0.6rem] font-black text-[var(--brand-highlight)] uppercase tracking-[0.3em] animate-pulse">Limited time offer</p>
                </div>
              )}
            </div>

            <!-- Action Hub (Creative CTA) -->
            <div class="mt-12 flex flex-col gap-6">
              <Button href={tile.buttonHref || "/contact"} variant="white" rounded-none="2xl" size="lg" className="w-full">
                {tile.buttonText}
              </Button>

              <a href={`tel:${tile.phone.replace(/[^0-9]/g, '')}`} class="flex items-center justify-center gap-3 text-[0.7rem] font-black text-white/20 uppercase tracking-[0.25em] transition-all duration-300 hover:text-[var(--brand-highlight)] hover:tracking-[0.3em]">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                {tile.phone}
              </a>
            </div>

            <!-- Light Sweep FX -->
            <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/[0.01] to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-[3s] pointer-events-none rounded-none"></div>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .pt-bento-card {
      min-height: auto;
    }
  }
</style>

