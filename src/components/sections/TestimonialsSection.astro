---
import { getLocationText } from "@/config/site"

interface Testimonial {
  name: string;
  initials: string;
  date: string;
  rating: number;
  content: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  testimonials: Testimonial[];
}

const { badge = "Testimonials", title: rawTitle, description: rawDescription, testimonials: rawTestimonials } = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
const testimonials = rawTestimonials.map(t => ({ ...t, content: getLocationText(t.content) }));
---

<section class="tm-section relative overflow-hidden bg-[#F8F9FA] py-24 lg:py-32">
  
  {/* Abstract Background Accent */}
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[var(--brand-primary)]/5 rounded-none blur-[120px] -translate-y-1/2 translate-x-1/3"></div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    
    <!-- Maximized Header Cluster -->
    <div class="mb-16 lg:mb-20" data-animate="fade-up">
      {badge && (
        <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-[var(--brand-primary)]/5 rounded-none border border-[var(--brand-primary)]/10 mb-10">
          <span class="w-2.5 h-2.5 rounded-none bg-[var(--brand-highlight)] animate-pulse"></span>
          <span class="text-xs font-black text-[var(--brand-primary)] uppercase tracking-[0.2em]">{badge}</span>
        </div>
      )}
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-6">
          <h2 class="text-4xl md:text-5xl lg:text-7xl font-black text-[var(--brand-primary)] uppercase tracking-tighter leading-[0.95] mb-0">
            {title}
          </h2>
        </div>

        {description && (
          <div class="lg:col-span-6">
            <div class="relative">
               <div class="absolute -left-8 top-0 bottom-0 w-1 bg-[var(--brand-highlight)] rounded-none hidden lg:block"></div>
               <p class="text-[1.05rem] text-[var(--brand-secondary)] lg:text-lg leading-relaxed font-medium max-w-2xl" set:html={description} />
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Cinematic Carousel with Progress Bar -->
    <div class="tm-carousel" data-animate="fade-up">
      <div class="tm-viewport overflow-visible">
        <div class="tm-track flex gap-5 lg:gap-6 cursor-grab active:cursor-grabbing select-none">
          {testimonials.map((t) => (
            <div class="tm-slide flex-shrink-0 w-full md:w-[calc(50%-10px)] lg:w-[calc(33.333%-16px)]">
              <div class="tm-card group relative h-full bg-white rounded-none lg:rounded-none p-8 lg:p-10 shadow-[0_10px_30px_-15px_rgba(0,0,0,0.05)] border border-gray-100 transition-all duration-700 hover:shadow-2xl hover:shadow-[var(--brand-primary)]/10 hover:-translate-y-3">
                
                <div class="flex items-center justify-between mb-8">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 flex items-center justify-center bg-white rounded-none shadow-sm border border-gray-50">
                      <svg viewBox="0 0 24 24" class="w-4 h-4"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 12-4.53z"/></svg>
                    </div>
                    <div class="tm-stars flex gap-0.5">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg xmlns="http://www.w3.org/2000/svg" class:list={["w-3.5 h-3.5", i < t.rating ? "text-[var(--brand-highlight)]" : "text-gray-200"]} viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      ))}
                    </div>
                  </div>
                  <div class="w-8 h-8 flex items-center justify-center bg-[var(--brand-primary)]/5 rounded-none text-[var(--brand-primary)] group-hover:bg-[var(--brand-highlight)] transition-colors duration-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 2.6C6.1 5.1 3 9.7 3 15v6h8v-8H7c0-3.3 1.7-6 4.6-7.4L11.3 2.6zM23.3 2.6C18.1 5.1 15 9.7 15 15v6h8v-8h-4c0-3.3 1.7-6 4.6-7.4L23.3 2.6z"/></svg>
                  </div>
                </div>

                <div class="flex-1">
                   <p class="text-[0.95rem] font-bold text-[var(--brand-primary)] leading-[1.7] mb-10" set:html={t.content} />
                </div>

                <div class="flex items-center gap-4 pt-6 border-t border-gray-50">
                  <div class="w-12 h-12 bg-[var(--brand-primary)] rounded-none flex items-center justify-center text-sm font-black text-[var(--brand-highlight)] group-hover:bg-[var(--brand-highlight)] group-hover:text-[var(--brand-primary)] transition-all duration-700">
                    <span>{t.initials}</span>
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[0.75rem] font-black text-[var(--brand-primary)] uppercase tracking-wider">{t.name}</span>
                    <span class="text-[0.65rem] font-bold text-[var(--brand-secondary)] uppercase tracking-[0.1em] opacity-60">{t.date}</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- High-End Progress Bar Controls -->
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-10 mt-16 lg:mt-24">
        
        <div class="hidden md:block flex-1"></div>

        {/* Arrow Navigation */}
        <div class="flex gap-4">
          <button aria-label="Previous Testimonial" class="tm-arrow tm-arrow--prev group w-16 h-16 rounded-none border border-gray-200 flex items-center justify-center transition-all duration-500 hover:bg-[var(--brand-primary)] hover:border-[var(--brand-primary)] hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-500 group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
          <button aria-label="Next Testimonial" class="tm-arrow tm-arrow--next group w-16 h-16 rounded-none border border-gray-200 flex items-center justify-center transition-all duration-500 hover:bg-[var(--brand-primary)] hover:border-[var(--brand-primary)] hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-500 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tm-track {
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.3, 1);
    will-change: transform;
  }
</style>

<script>
  function initTestimonialsCarousel() {
    document.querySelectorAll<HTMLElement>('.tm-carousel').forEach((carousel) => {
      const viewport = carousel.querySelector<HTMLElement>('.tm-viewport');
      const track = carousel.querySelector<HTMLElement>('.tm-track');
      const prevBtn = carousel.querySelector<HTMLElement>('.tm-arrow--prev');
      const nextBtn = carousel.querySelector<HTMLElement>('.tm-arrow--next');
      const progressFill = carousel.querySelector<HTMLElement>('.tm-progress-fill');
      const totalCountLabel = carousel.querySelector<HTMLElement>('.tm-total-count');
      
      if (!viewport || !track || !prevBtn || !nextBtn) return;
      if (track.dataset.init === 'true') return;
      track.dataset.init = 'true';

      let slides = Array.from(track.querySelectorAll<HTMLElement>('.tm-slide'));
      const totalSlides = slides.length;
      if (totalSlides === 0) return;

      const getPerView = () => {
        if (window.innerWidth >= 1024) return 3;
        if (window.innerWidth >= 768) return 2;
        return 1;
      };

      let perView = getPerView();
      let currentIndex = perView; // Start at first real slide
      let isTransitioning = false;
      let autoplayInterval: any = null;

      // Clone slides for infinite effect
      const clonesBefore = slides.slice(-perView).map(s => s.cloneNode(true) as HTMLElement);
      const clonesAfter = slides.slice(0, perView).map(s => s.cloneNode(true) as HTMLElement);
      
      clonesBefore.reverse().forEach(clone => track.insertBefore(clone, track.firstChild));
      clonesAfter.forEach(clone => track.appendChild(clone));

      const allSlides = Array.from(track.querySelectorAll<HTMLElement>('.tm-slide'));

      if (totalCountLabel) {
        totalCountLabel.textContent = totalSlides.toString().padStart(2, '0');
      }
      
      function updateUI(smooth = true) {
        const gap = window.innerWidth >= 1024 ? 24 : 20;
        const slideWidth = (slides[0] as HTMLElement).offsetWidth + gap;
        
        track!.style.transition = smooth ? 'transform 0.8s cubic-bezier(0.25, 1, 0.3, 1)' : 'none';
        track!.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
        
        if (progressFill) {
          let realIndex = (currentIndex - perView + totalSlides) % totalSlides;
          const progress = (realIndex / (totalSlides - 1));
          progressFill.style.transform = `scaleX(${Math.max(0.05, progress)})`;
        }
      }

      function handleTransitionEnd() {
        isTransitioning = false;
        const slideCount = allSlides.length;
        
        if (currentIndex >= slideCount - perView) {
          currentIndex = perView;
          updateUI(false);
        } else if (currentIndex < perView) {
          currentIndex = slideCount - perView * 2;
          updateUI(false);
        }
      }

      track.addEventListener('transitionend', handleTransitionEnd);

      function goTo(index: number) {
        if (isTransitioning) return;
        isTransitioning = true;
        currentIndex = index;
        updateUI();
      }

      function startAutoplay() {
        stopAutoplay();
        autoplayInterval = setInterval(() => {
          goTo(currentIndex + 1);
        }, 5000);
      }

      function stopAutoplay() {
        if (autoplayInterval) clearInterval(autoplayInterval);
      }

      prevBtn.addEventListener('click', () => { goTo(currentIndex - 1); startAutoplay(); });
      nextBtn.addEventListener('click', () => { goTo(currentIndex + 1); startAutoplay(); });

      carousel.addEventListener('mouseenter', stopAutoplay);
      carousel.addEventListener('mouseleave', startAutoplay);

      window.addEventListener('resize', () => {
        perView = getPerView();
        currentIndex = perView;
        updateUI(false);
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            startAutoplay();
          } else {
            stopAutoplay();
          }
        });
      }, { threshold: 0.1 });

      observer.observe(carousel);
      setTimeout(() => updateUI(false), 50);
    });
  }

  initTestimonialsCarousel();
  document.addEventListener('astro:page-load', initTestimonialsCarousel);
</script>

