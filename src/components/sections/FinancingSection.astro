---
interface Step {
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  paymentPlans: string[];
  financingOptions: string[];
  steps: Step[];
  buttonText?: string;
  buttonHref?: string;
}

const {
  badge = "FINANCING",
  title,
  description,
  paymentPlans,
  financingOptions,
  steps,
  buttonText = "APPLY NOW",
  buttonHref = "/financing",
} = Astro.props;
---

<section class="fin-section relative overflow-hidden bg-[var(--brand-primary)] py-20 lg:py-28" id="financing-section">
  <!-- Dynamic Architectural Accents -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-white/[0.02] -skew-x-12 translate-x-1/4 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-[var(--brand-highlight)]/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 relative z-10">
    
    <!-- Balanced Dark Header -->
    <div class="max-w-4xl mb-16 lg:mb-20 reveal-on-scroll">
      <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-white/5 rounded-full border border-white/10 mb-6">
        <span class="w-2.5 h-2.5 rounded-full bg-[var(--brand-highlight)] animate-pulse"></span>
        <span class="text-[0.65rem] font-black text-white/80 uppercase tracking-[0.25em]">{badge}</span>
      </div>
      
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-tight leading-[1.0] mb-8">
        {title}
      </h2>
      
      <div class="text-white/60 text-base lg:text-lg font-medium leading-relaxed max-w-2xl" set:html={description} />
    </div>

    <!-- Glassmorphic Architectural Lists -->
    <div class="grid lg:grid-cols-2 gap-6 lg:gap-8 mb-20 lg:mb-28">
      
      <!-- List 1: Why Choose -->
      <div class="group relative bg-white/[0.03] backdrop-blur-sm rounded-[2.5rem] p-10 lg:p-12 transition-all duration-700 hover:bg-white/[0.06] hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.3)] border border-white/5 hover:border-white/10 overflow-hidden reveal-on-scroll" style="transition-delay: 100ms;">
        <div class="absolute top-[-5%] right-[-5%] text-[8rem] font-black text-white/[0.02] select-none pointer-events-none">?</div>
        
        <div class="relative z-10">
          <h3 class="text-lg font-black uppercase text-white tracking-widest mb-8 pb-4 border-b border-white/10 flex items-center gap-4">
            <span class="w-1.5 h-5 bg-[var(--brand-highlight)] rounded-full"></span>
            Why Choose Our Financing?
          </h3>
          
          <ul class="space-y-5">
            {paymentPlans.map((plan) => (
              <li class="flex items-center gap-4 text-white/70 font-bold group/item">
                <div class="w-8 h-8 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[var(--brand-highlight)] shadow-sm transition-all duration-300 group-hover/item:bg-[var(--brand-highlight)] group-hover/item:text-[var(--brand-primary)] group-hover/item:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <span class="text-xs uppercase tracking-wide group-hover/item:text-white transition-colors">{plan}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- List 2: What Can You Finance -->
      <div class="group relative bg-white/[0.03] backdrop-blur-sm rounded-[2.5rem] p-10 lg:p-12 transition-all duration-700 hover:bg-white/[0.06] hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.3)] border border-white/5 hover:border-white/10 overflow-hidden reveal-on-scroll" style="transition-delay: 300ms;">
        <div class="absolute top-[-5%] right-[-5%] text-[8rem] font-black text-white/[0.02] select-none pointer-events-none">$</div>

        <div class="relative z-10">
          <h3 class="text-lg font-black uppercase text-white tracking-widest mb-8 pb-4 border-b border-white/10 flex items-center gap-4">
            <span class="w-1.5 h-5 bg-[var(--brand-highlight)] rounded-full"></span>
            What Can You Finance?
          </h3>
          
          <ul class="space-y-5">
            {financingOptions.map((option) => (
              <li class="flex items-center gap-4 text-white/70 font-bold group/item">
                <div class="w-8 h-8 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[var(--brand-highlight)] shadow-sm transition-all duration-300 group-hover/item:bg-[var(--brand-highlight)] group-hover/item:text-[var(--brand-primary)] group-hover/item:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
                <span class="text-xs uppercase tracking-wide group-hover/item:text-white transition-colors">{option}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>

    <!-- The Process: Balanced Path -->
    <div class="relative mb-20 lg:mb-28">
      <div class="hidden lg:block absolute top-10 left-0 w-full h-px bg-white/10 z-0"></div>
      
      <div class="grid md:grid-cols-3 gap-10 relative z-10">
        {steps.map((step, i) => (
          <div class="group reveal-on-scroll" style={`transition-delay: ${i * 150}ms;`}>
            <div class="flex items-center gap-5 mb-6 lg:mb-10">
               <div class="w-20 h-20 bg-white/5 border border-white/10 rounded-[2rem] flex items-center justify-center text-white font-black text-2xl shadow-sm transition-all duration-700 group-hover:bg-[var(--brand-highlight)] group-hover:text-[var(--brand-primary)] group-hover:scale-110 group-hover:rotate-6">
                 0{i + 1}
               </div>
               <div class="lg:hidden h-px flex-grow bg-white/10"></div>
            </div>
            
            <h4 class="text-base font-black uppercase text-white tracking-widest mb-3 group-hover:text-[var(--brand-highlight)] transition-colors">
              {step.title}
            </h4>
            <p class="text-[0.8rem] text-white/40 font-medium leading-relaxed max-w-[260px]" set:html={step.description} />
          </div>
        ))}
      </div>
    </div>

    <!-- Balanced Brand Footer -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-10 pt-12 border-t border-white/10 reveal-on-scroll">
      <div class="flex items-center gap-6">
        <div class="text-5xl font-black text-white/5 select-none">FNC</div>
        <p class="text-[0.6rem] font-black uppercase tracking-[0.35em] text-white/30 max-w-[180px] leading-relaxed">
          Flexible Payment Solutions for Every Home
        </p>
      </div>

      <a href={buttonHref} class="relative inline-flex items-center gap-5 px-12 py-6 bg-[var(--brand-highlight)] text-[var(--brand-primary)] font-black text-[0.85rem] uppercase tracking-widest rounded-full transition-all duration-700 hover:bg-white hover:scale-105 group/btn overflow-hidden">
        <span class="relative z-10">{buttonText}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 relative z-10 transition-transform duration-500 group-hover/btn:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
        <div class="absolute inset-0 bg-white/30 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 skew-x-12"></div>
      </a>
    </div>

  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.25, 1, 0.3, 1);
  }
  
  .reveal-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initFinancingAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  initFinancingAnimations();
  document.addEventListener('astro:page-load', initFinancingAnimations);
</script>
